---
import logo from "../assets/logo-blanco.png";
const p = Astro.url.pathname;

const links = [
  { href: "/",              label: "Inicio",   active: p === "/" },
  { href: "/servicios",     label: "Servicios",active: p.startsWith("/servicios") },
  { href: "/formacion",     label: "Formación",active: p.startsWith("/formacion") },
  { href: "/sobre-nosotros",label: "Nosotros", active: p.startsWith("/sobre-nosotros") },
  { href: "/contacto",      label: "Contacto", active: p.startsWith("/contacto") },
];
---

<nav id="main-nav" class="nav-enter w-full" style="background: #fff; border-bottom: 1px solid rgba(201,160,199,0.3);">

  <div class="max-w-7xl mx-auto flex justify-between items-center h-[68px] px-6 lg:px-8">

    <!-- Logo: filter para hacerlo visible en fondo blanco -->
    <a href="/" class="flex items-center flex-shrink-0 group" aria-label="Lashes Esmera">
      <img
        src={logo.src}
        alt="Lashes Esmera"
        class="h-9 w-auto object-contain transition-opacity duration-300 group-hover:opacity-60"
        style="filter: brightness(0) saturate(0);"
      />
    </a>

    <!-- Desktop links -->
    <ul class="hidden lg:flex items-center gap-0.5">
      {links.map(({ href, label, active }) => (
        <li>
          <a
            href={href}
            class={`nav-link relative px-4 py-2.5 text-[12.5px] tracking-[0.06em] inline-block transition-colors duration-200
              ${active
                ? "font-semibold is-active"
                : "font-medium hover:text-[#5c2d5a]"
              }`}
            style={active ? "color: #2d1229;" : "color: #9c7a9a;"}
          >
            {label}
            <span class="nav-link-underline"></span>
          </a>
        </li>
      ))}

      <li>
        <a
          href="/tienda"
          class="nav-link relative px-4 py-2.5 text-[12.5px] tracking-[0.06em] font-medium inline-flex items-center gap-1.5 transition-colors duration-200 hover:text-[#5c2d5a]"
          style="color: #9c7a9a;"
        >
          Tienda
          <svg class="w-2.5 h-2.5 opacity-60" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
          <span class="nav-link-underline"></span>
        </a>
      </li>
    </ul>

    <!-- CTA Desktop -->
    <a
      href="https://wa.me/34600000000"
      class="hidden lg:flex items-center gap-2 text-[12.5px] font-semibold tracking-wide px-5 py-2.5 rounded-full transition-all duration-300 nav-cta-btn"
      style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); color: #fff;"
    >
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Reservar cita
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="lg:hidden p-2 rounded-lg transition-all duration-200"
      style="color: #9c5a96;"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span id="hamburger-icon" class="relative block w-5 h-3.5">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden overflow-hidden"
    style="max-height: 0; opacity: 0; transition: max-height 0.4s cubic-bezier(0.22,1,0.36,1), opacity 0.3s ease; background: #fff;"
  >
    <div class="px-5 pb-7 pt-2" style="border-top: 1px solid rgba(201,160,199,0.25);">
      <nav class="flex flex-col gap-0.5">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class="px-4 py-3.5 text-[14px] font-medium rounded-xl transition-all duration-150"
            style="color: #7a4a78;"
            onmouseover="this.style.background='#fdf2fd'; this.style.color='#4a2048';"
            onmouseout="this.style.background=''; this.style.color='#7a4a78';"
          >
            {label}
          </a>
        ))}

        <a
          href="/tienda"
          class="px-4 py-3.5 text-[14px] font-medium rounded-xl transition-all duration-150 flex items-center gap-2"
          style="color: #7a4a78;"
          onmouseover="this.style.background='#fdf2fd';" onmouseout="this.style.background='';"
        >
          Tienda
          <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
          </svg>
        </a>

        <div class="mt-3 px-1">
          <a
            href="https://wa.me/34600000000"
            class="flex items-center justify-center gap-2 text-[14px] font-semibold py-3.5 rounded-2xl transition-all duration-200 active:scale-95"
            style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); color: #fff; box-shadow: 0 4px 20px rgba(156,90,150,0.25);"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Reservar cita por WhatsApp
          </a>
        </div>
      </nav>
    </div>
  </div>

</nav>

<style>
  .nav-cta-btn {
    transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 2px 16px rgba(156, 90, 150, 0.28);
  }
  .nav-cta-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 4px 28px rgba(156, 90, 150, 0.38) !important;
  }
</style>

<script is:inline>
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const hIcon  = document.getElementById('hamburger-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = hIcon?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!isOpen));
    if (isOpen) {
      menu.style.maxHeight = menu.scrollHeight + 'px';
      menu.style.opacity   = '1';
    } else {
      menu.style.maxHeight = '0';
      menu.style.opacity   = '0';
    }
  });

  const nav = document.getElementById('main-nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('nav-scrolled', window.scrollY > 50);
  }, { passive: true });
</script>
