---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="min-h-screen flex items-center justify-center bg-white px-6">
    <div class="text-center max-w-xl">
      <!-- Código -->
      <h1 class="text-6xl md:text-7xl font-bold text-black mb-4">404</h1>

      <!-- Título -->
      <h2 class="text-2xl md:text-3xl font-semibold mb-4">
        Página no encontrada
      </h2>

      <!-- Texto -->
      <p class="text-gray-600 mb-10">
        La página que buscas no existe o ha sido movida.
      </p>

      <!-- Botones -->
      <div class="flex flex-col md:flex-row justify-center gap-4">
        <a
          href="/"
          class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
        >
          Volver al inicio
        </a>

        <a
          href="/formacion"
          class="border border-black px-8 py-3 rounded-full text-sm hover:bg-black hover:text-white transition"
        >
          Ver formación
        </a>
      </div>
    </div>
  </section>
</Layout>
