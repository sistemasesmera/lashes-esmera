---
import { Image } from "astro:assets";
import logo from "../assets/logo-blanco.png";
const currentYear = new Date().getFullYear();
---

<footer style="background: #1a0a18; color: #fff;">

  <!-- CONTENIDO PRINCIPAL -->
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-12 grid md:grid-cols-3 gap-12 items-start">

    <!-- MARCA -->
    <div class="flex flex-col items-center md:items-start text-center md:text-left">
      <Image src={logo} alt="Lashes Esmera" width={80} height={80} class="opacity-90" />
      <p class="mt-5 text-gray-400 leading-relaxed text-sm max-w-xs">
        Especialistas en cejas y pestañas en Madrid. Formación, servicios y productos profesionales para lash artists.
      </p>
    </div>

    <!-- NAVEGACIÓN -->
    <div class="flex flex-col items-center text-center">
      <h4 class="text-xs font-semibold tracking-widest mb-6 text-gray-500 uppercase">
        Navegación
      </h4>
      <ul class="space-y-3 text-sm">
        <li><a href="/" class="text-gray-400 hover:text-white transition">Inicio</a></li>
        <li><a href="/servicios" class="text-gray-400 hover:text-white transition">Servicios</a></li>
        <li><a href="/formacion" class="text-gray-400 hover:text-white transition">Formación</a></li>
        <li>
          <a href="/tienda" class="text-gray-400 hover:text-white transition">
            Tienda
          </a>
        </li>
        <li><a href="/sobre-nosotros" class="text-gray-400 hover:text-white transition">Nosotros</a></li>
        <li><a href="/contacto" class="text-gray-400 hover:text-white transition">Contacto</a></li>
      </ul>
    </div>

    <!-- CONTACTO -->
    <div class="flex flex-col items-center md:items-end text-center md:text-right">
      <h4 class="text-xs font-semibold tracking-widest mb-6 text-gray-500 uppercase">
        Contacto
      </h4>
      <p class="text-gray-400 text-sm">Madrid, España</p>
      <a href="tel:+34600000000" class="mt-3 text-gray-400 text-sm hover:text-white transition">
        +34 600 00 00 00
      </a>
      <a href="mailto:info@lashesesmera.com" class="text-gray-400 text-sm hover:text-white transition">
        info@lashesesmera.com
      </a>
      <a
        href="https://wa.me/34600000000"
        class="mt-6 inline-block px-6 py-2.5 rounded-full text-xs font-semibold tracking-wide transition hover:scale-105"
        style="background: #f1cdf0; color: #5c2d5a;"
      >
        RESERVAR POR WHATSAPP
      </a>
    </div>
  </div>

  <!-- DIVISOR -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-t border-white/10"></div>
  </div>

  <!-- FOOTER BOTTOM -->
  <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-600">
    <p>© {currentYear} Lashes Esmera. Todos los derechos reservados.</p>
    <div class="flex gap-5">
      <a href="/politica-privacidad" class="hover:text-gray-300 transition">Privacidad</a>
      <a href="/terminos" class="hover:text-gray-300 transition">Términos</a>
      <a href="/aviso-legal" class="hover:text-gray-300 transition">Legal</a>
    </div>
  </div>

</footer>
