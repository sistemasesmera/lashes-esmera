---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
const {
  title = "Lashes Esmera | Expertos en cejas y pestañas en Madrid",
  description = "Especialistas en cejas y pestañas en Madrid. Ofrecemos servicios profesionales, formación especializada y productos para lash artists.",
  canonical = "https://lashesesmera.com",
  // Nueva prop: controla si se muestra el Navbar (true por defecto)
  showNavbar = true,
  // Opcional: si true muestra un mini header (logo centrado) en lugar del navbar
  miniHeader = false,
  // Nueva prop: controla si se muestra el Footer (true por defecto)
  showFooter = true,
} = Astro.props;

const hasHeader = showNavbar || miniHeader;
---

<!doctype html>
<html lang="es">
  <head>
    <noscript
      ><img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=2100550244114532&ev=PageView&noscript=1"
      /></noscript
    >

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta charset="UTF-8" />
    <meta
      name="keywords"
      content="extensiones de pestañas Madrid, lifting de pestañas, laminado de cejas, diseño de cejas, cursos de pestañas Madrid, cursos de cejas, formación estética, lash artist, productos de pestañas, productos de cejas, academia de pestañas Madrid, estética profesional Madrid"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Redes sociales) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Lashes Esmera" />

    <!-- Open Graph Images -->
    <meta
      property="og:image"
      content="https://i.ibb.co/qLkp56BH/og-image.png"
    />

    <meta
      property="og:image:alt"
      content="Lashes Esmera - especialistas en cejas y pestañas en Madrid"
    />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BeautySalon",
        "name": "Lashes Esmera",
        "url": "https://lashesesmera.com",
        "logo": "https://lashesesmera.com/favicon-esmera.svg",
        "description": "Lashes Esmera es una marca especializada en cejas y pestañas que ofrece servicios profesionales, formación especializada y productos de alta calidad en Madrid.",
        "foundingDate": "2025",
        "founder": {
          "@type": "Organization",
          "name": "Esmera School"
        },
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Paseo Santa Maria de la Cabeza 10, Local 2",
          "addressLocality": "Madrid",
          "postalCode": "28045",
          "addressCountry": "ES"
        },
        "contactPoint": [
          {
            "@type": "ContactPoint",
            "telephone": "+34673753508",
            "contactType": "customer service",
            "areaServed": "ES",
            "availableLanguage": ["Spanish"]
          }
        ],
        "openingHours": "Mo-Su 10:00-22:00",
        "sameAs": [
          "https://www.instagram.com/TU_CUENTA",
          "https://www.facebook.com/TU_PAGINA"
        ],
        "knowsLanguage": ["Spanish"]
      }
    </script>
  </head>

  <body class="flex flex-col min-h-screen">
    <!-- Renderizado condicional del navbar / mini header -->
    {
      showNavbar ? (
        <div>
          <Navbar />
        </div>
      ) : (
        miniHeader && (
          <header class="py-6 bg-white shadow-sm">
            <div class="max-w-6xl mx-auto px-6 flex items-center justify-center">
              <a
                href="/"
                aria-label="Esmera School - Inicio"
                class="inline-block"
              >
                <img
                  src="/favicon-esmera.svg"
                  alt="Esmera School"
                  class="h-10"
                />
              </a>
            </div>
          </header>
        )
      )
    }
    <main class={`flex-1 ${hasHeader ? "pt-16" : ""}`}>
      <slot />
    </main>

    {showFooter ? <h2> Footer </h2> : null}
  </body>
</html>

<!-- Script para controlar el modal -->
<script src="/modal.js" type="module"></script>
