---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const cursos = await getCollection("cursos");

  return cursos.map((curso) => ({
    params: { slug: curso.id },
    props: { curso },
  }));
}

const { curso } = Astro.props;
const data = curso.data;
---

<Layout
  title={`${data.title} | Lashes Esmera`}
  description={data.description}
  canonical={`https://lashesesmera.com/formacion/${curso.id}`}
>
  <!-- HERO -->
  <section
    class="relative h-[60vh] flex items-center justify-center text-center"
  >
    <img
      src={data.banner_desktop}
      alt={data.title}
      class="absolute inset-0 w-full h-full object-cover brightness-75"
    />
    <div class="absolute inset-0 bg-black/60"></div>

    <div class="relative z-10 px-6 text-white max-w-2xl">
      <span class="text-xs uppercase tracking-widest text-gray-300 font-bold">{data.modality}</span>
      <h1 class="text-3xl md:text-5xl font-bold mt-4">{data.title}</h1>
      <p class="mt-4 text-gray-200">{data.short_description}</p>
    </div>
  </section>

  <!-- CONTENIDO Y FORMULARIO -->
  <section
    class="py-16 px-6 max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-10"
  >
    <!-- COLUMNA IZQUIERDA: DESCRIPCIÓN -->
    <div class="lg:col-span-2 space-y-8">
      <div>
        <h2 class="text-2xl font-semibold mb-4">Descripción del curso</h2>
        <p class="text-gray-700 leading-relaxed">{data.description}</p>
      </div>

      {
        data.benefits && (
          <div>
            <h2 class="text-2xl font-semibold mb-4">Beneficios</h2>
            <ul class="space-y-3">
              {data.benefits.map((b) => (
                <li class="bg-gray-50 p-4 rounded-xl flex items-start gap-2 text-sm shadow-sm hover:shadow-md transition">
                  <span class="text-green-500 font-bold mt-1">✔</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- PREGUNTAS FRECUENTES -->
      <div class="mt-12">
        <h2 class="text-2xl font-semibold mb-6 text-center">Preguntas Frecuentes</h2>

        <div class="space-y-4">
          <div class="accordion border-b border-gray-300">
            <button class="accordion-header w-full text-left font-medium py-3 flex justify-between items-center">
                ¿Necesito experiencia previa?
              <span class="icon">+</span>
            </button>
            <div class="accordion-content max-h-0 overflow-hidden transition-all duration-300">
              <p class="p-3 text-gray-700">No es necesario. Los cursos están diseñados tanto para principiantes como para profesionales que quieren especializarse en técnicas de cejas y pestañas.</p>
            </div>
          </div>

          <div class="accordion border-b border-gray-300">
            <button class="accordion-header w-full text-left font-medium py-3 flex justify-between items-center">
              ¿Se entrega certificado?
              <span class="icon">+</span>
            </button>
            <div class="accordion-content max-h-0 overflow-hidden transition-all duration-300">
              <p class="p-3 text-gray-700">Sí, todos los cursos incluyen un certificado oficial que acredita tu formación profesional.</p>
            </div>
          </div>

          <div class="accordion border-b border-gray-300">
            <button class="accordion-header w-full text-left font-medium py-3 flex justify-between items-center">
                ¿Puedo trabajar profesionalmente después de completar el curso?
              <span class="icon">+</span>
            </button>
            <div class="accordion-content max-h-0 overflow-hidden transition-all duration-300">
              <p class="p-3 text-gray-700">Sí, nuestros cursos están pensados para que puedas ofrecer servicios profesionales de manera inmediata en salones, estudios o a domicilio.</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- COLUMNA DERECHA: FORMULARIO -->
    <aside class="lg:col-span-1">
      <div
        id="formulario"
        class="sticky top-24 bg-gray-900 shadow-2xl rounded-2xl p-8 text-white space-y-6 border border-gray-700"
      >
        <h3 class="text-2xl font-bold text-center mb-2">Contáctanos</h3>
        <p class="text-gray-300 text-center mb-6">
          Un asesor educativo se pondrá en contacto contigo.
        </p>

        <form id="curso-form" class="space-y-4" data-course-name={data.title}>
          <div>
            <label class="block text-sm font-medium text-gray-300">Nombre *</label>
            <input
              type="text"
              name="name"
              placeholder="Tu nombre"
              required
              class="mt-1 block w-full rounded-lg bg-gray-800 border border-gray-700 text-white px-4 py-3 shadow-sm focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-all duration-300 placeholder-gray-400"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300">Email *</label>
            <input
              type="email"
              name="email"
              placeholder="correo@ejemplo.com"
              required
              class="mt-1 block w-full rounded-lg bg-gray-800 border border-gray-700 text-white px-4 py-3 shadow-sm focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-all duration-300 placeholder-gray-400"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-300">Teléfono *</label>
            <input
              type="tel"
              name="phone"
              placeholder="600000000"
              pattern="[0-9]{9}"
              required
              class="mt-1 block w-full rounded-lg bg-gray-800 border border-gray-700 text-white px-4 py-3 shadow-sm focus:ring-2 focus:ring-blue-600 focus:border-blue-600 transition-all duration-300 placeholder-gray-400"
            />
          </div>

          <!-- Checkboxes -->
          <div class="space-y-2">
            <label class="flex flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-3 text-xs text-gray-300">
              <input
                type="checkbox"
                name="terminos"
                required
                class="h-5 w-5 rounded border-gray-600 bg-gray-700 focus:ring-2 focus:ring-blue-600 accent-blue-500"
              />
              <span class="flex flex-wrap gap-1">
                Acepto los
                <a href="/terminos" class="underline hover:text-blue-400">Términos y Condiciones</a>
                y la
                <a href="/politicas-de-privacidad" class="underline hover:text-blue-400">Política de Privacidad</a>.
              </span>
            </label>

            <label class="flex items-center gap-3 text-xs text-gray-300">
              <input
                type="checkbox"
                name="publicidad"
                class="h-5 w-5 rounded border-gray-600 bg-gray-700 focus:ring-2 focus:ring-blue-600 accent-blue-500"
              />
              Deseo recibir comunicaciones comerciales y promociones
            </label>
          </div>

          <button
            type="submit"
            class="w-full bg-blue-700 hover:bg-blue-800 text-white font-semibold py-3 rounded-lg shadow-lg transition transform hover:scale-[1.02]"
          >
            Enviar
          </button>

          <p id="curso-form-message" class="text-sm text-center text-gray-300 mt-2"></p>
        </form>
      </div>
    </aside>
  </section>
</Layout>

<script>
  // Accordion FAQ
  document.querySelectorAll(".accordion-header").forEach((btn) => {
    btn.addEventListener("click", () => {
      const parent = btn.parentElement;
      parent.classList.toggle("open");
    });
  });

  // Formulario
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.getElementById("curso-form");
    const message = document.getElementById("curso-form-message");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const name = form.name.value.trim();
      const email = form.email.value.trim();
      const phone = form.phone.value.trim();
      const terminos = form.terminos.checked;
      const publicidad = form.publicidad.checked;
      const nameCourse = form.dataset.courseName;

      if (!name || !email || !phone || !terminos) {
        message.textContent = "Todos los campos obligatorios y aceptar términos.";
        message.className = "text-red-500 text-sm text-center mt-2";
        return;
      }

      try {
        message.textContent = "Enviando...";
        message.className = "text-blue-200 text-sm text-center mt-2";

        const res = await fetch(
          "https://esmera-manager-backend.onrender.com/leads",
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              name,
              email,
              phone,
              course: nameCourse,
              publicidad,
            }),
          }
        );

        if (!res.ok) throw new Error("Error del servidor");

        message.textContent = "¡Formulario enviado con éxito!";
        message.className = "text-green-400 text-sm text-center mt-2";
        form.reset();
      } catch {
        message.textContent = "Error al enviar. Intenta nuevamente.";
        message.className = "text-red-500 text-sm text-center mt-2";
      }
    });
  });
</script>

<style>
  /* Accordion */
  .accordion-header {
    display: flex;
    justify-content: space-between;
    width: 100%;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #111827;
  }

  .accordion-content {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .accordion.open .accordion-content {
    opacity: 1;
    max-height: 500px;
  }

  .accordion .icon {
    transition: transform 0.3s ease;
  }

  .accordion.open .icon {
    transform: rotate(45deg);
  }
</style>