---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import TopBar from "../components/TopBar.astro";
import "../styles/global.css";

const {
  title = "Lashes Esmera | Expertos en cejas y pestañas en Madrid",
  description = "Especialistas en cejas y pestañas en Madrid. Ofrecemos servicios profesionales, formación especializada y productos para lash artists.",
  canonical = "https://lashesesmera.com",
  showNavbar = true,
  miniHeader = false,
  showFooter = true,
} = Astro.props;

const hasHeader = showNavbar || miniHeader;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- META RESPONSIVE (CLAVE) -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=2100550244114532&ev=PageView&noscript=1"
      />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta charset="UTF-8" />
    <meta
      name="keywords"
      content="extensiones de pestañas Madrid, lifting de pestañas, laminado de cejas, cursos estética Madrid"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Lashes Esmera" />
    <meta
      property="og:image"
      content="https://i.ibb.co/qLkp56BH/og-image.png"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BeautySalon",
        "name": "Lashes Esmera",
        "url": "https://lashesesmera.com"
      }
    </script>
  </head>

  <body class="flex flex-col min-h-screen bg-white text-gray-900">
    <!-- HEADER -->
    {
      showNavbar ? (
        <header class="w-full fixed top-0 left-0 z-50 bg-white/80 backdrop-blur-md shadow-sm">
          <TopBar />
          <Navbar />
        </header>
      ) : (
        miniHeader && (
          <header class="w-full py-4 bg-white shadow-sm fixed top-0 left-0 z-50">
            <div class="max-w-6xl mx-auto px-4 flex items-center justify-center">
              <a href="/" aria-label="Inicio">
                <img
                  src="/favicon-esmera.svg"
                  alt="Lashes Esmera"
                  class="h-8 md:h-10"
                />
              </a>
            </div>
          </header>
        )
      )
    }

    <!-- MAIN -->
    <main class={`flex-1 w-full ${hasHeader ? "pt-14 md:pt-14" : ""}`}>
      <div class="w-full mx-auto">
        <slot />
      </div>
    </main>

    <!-- FOOTER -->
    {
      showFooter && (
        <footer class="w-full mt-auto">
          <Footer />
        </footer>
      )
    }
  </body>
</html>

<!-- SCRIPT -->
<script src="/modal.js" type="module"></script>
