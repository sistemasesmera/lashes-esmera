---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Lashes Esmera | Formación, servicios y productos de cejas y pestañas"
  description="Especialistas en cejas y pestañas en Madrid. Formación profesional, servicios y productos para lash artists."
  canonical="https://lashesesmera.com/"
>
  <!-- HERO -->
  <section class="bg-[#f1cdf0] pt-32 pb-20 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-black mb-6">
      Conviértete en experta en cejas y pestañas
    </h1>

    <p class="text-lg text-gray-800 max-w-xl mx-auto mb-8">
      Formación profesional, productos especializados y servicios de alta
      calidad en Madrid.
    </p>

    <div class="flex flex-col md:flex-row justify-center gap-4">
      <a
        href="/formacion"
        class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
      >
        Ver formación
      </a>

      <a
        href="https://tienda.lashesesmera.com"
        class="border border-black px-8 py-3 rounded-full text-sm hover:bg-black hover:text-white transition"
      >
        Ver productos
      </a>
    </div>
  </section>

  <!-- FORMACIÓN (PRIORIDAD 1) -->
  <section
    class="py-24 px-6 max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center"
  >
    <!-- Imagen -->
    <div
      class="w-full h-80 bg-gray-200 rounded-2xl flex items-center justify-center"
    >
      <span class="text-gray-500">Imagen formación</span>
    </div>

    <!-- Texto -->
    <div>
      <h2 class="text-3xl font-semibold mb-4">Formación profesional</h2>

      <p class="text-gray-700 mb-6">
        Aprende desde cero o perfecciona tus técnicas con nuestros cursos
        especializados en cejas y pestañas. Formación práctica, real y orientada
        al mercado.
      </p>

      <a
        href="/formacion"
        class="bg-black text-white px-6 py-3 rounded-full text-sm hover:bg-gray-800 transition"
      >
        Ver cursos
      </a>
    </div>
  </section>

  <!-- PRODUCTOS (PRIORIDAD 2) -->
  <section class="bg-gray-50 py-24 px-6 text-center">
    <h2 class="text-3xl font-semibold mb-4">Productos profesionales</h2>

    <p class="text-gray-700 mb-10 max-w-xl mx-auto">
      Descubre nuestra línea de productos para lash artists y especialistas en
      cejas.
    </p>

    <!-- Simulación productos -->
    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto mb-10">
      <div class="bg-white p-6 rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <p class="text-sm">Kit extensiones</p>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <p class="text-sm">Pinzas profesionales</p>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <p class="text-sm">Productos cejas</p>
      </div>
    </div>

    <a
      href="https://tienda.lashesesmera.com"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Ir a la tienda
    </a>
  </section>

  <!-- SERVICIOS (PRIORIDAD 3) -->
  <section class="py-24 px-6 max-w-6xl mx-auto text-center">
    <h2 class="text-3xl font-semibold mb-10">Servicios en estudio</h2>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="p-6 bg-white rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <h3 class="font-semibold mb-2">Extensiones</h3>
        <p class="text-gray-600 text-sm">Clásicas, volumen y mega volumen</p>
      </div>

      <div class="p-6 bg-white rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <h3 class="font-semibold mb-2">Lifting</h3>
        <p class="text-gray-600 text-sm">Resultado natural y duradero</p>
      </div>

      <div class="p-6 bg-white rounded-xl shadow-sm">
        <div class="h-40 bg-gray-200 rounded mb-4"></div>
        <h3 class="font-semibold mb-2">Cejas</h3>
        <p class="text-gray-600 text-sm">Diseño y laminado profesional</p>
      </div>
    </div>

    <a
      href="https://wa.me/34600000000"
      class="inline-block mt-10 border border-black px-8 py-3 rounded-full text-sm hover:bg-black hover:text-white transition"
    >
      Reservar cita
    </a>
  </section>

  <!-- CTA FINAL -->
  <section class="bg-[#f1cdf0] py-16 px-6 text-center">
    <h2 class="text-2xl font-semibold mb-4">
      Empieza hoy en el mundo de las lashes
    </h2>

    <p class="text-gray-800 mb-6">
      Formación, productos y servicios en un solo lugar.
    </p>

    <a
      href="/formacion"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Quiero formarme
    </a>
  </section>
</Layout>
