---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Cursos de cejas y pestañas en Madrid | Lashes Esmera"
  description="Fórmate en extensiones de pestañas, volumen ruso, lifting y cejas. Cursos profesionales en Madrid con formación práctica y real."
  canonical="https://lashesesmera.com/formacion"
/>
<!-- HERO -->
<section class="bg-[#f1cdf0] pt-32 pb-20 px-6 text-center">
  <h1 class="text-4xl md:text-5xl font-bold text-black mb-6">
    Conviértete en lash artist profesional
  </h1>

  <p class="text-lg text-gray-800 max-w-xl mx-auto mb-8">
    Formación especializada en cejas y pestañas con técnicas actuales y enfoque
    profesional.
  </p>

  <a
    href="#formulario"
    class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
  >
    Quiero información
  </a>
</section>

<!-- CURSOS -->
<section class="py-24 px-6 max-w-6xl mx-auto text-center">
  <h2 class="text-3xl font-semibold mb-12">Nuestros cursos</h2>

  <div class="grid md:grid-cols-3 gap-8">
    <!-- 1 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Curso básico extensiones</h3>
      <p class="text-gray-600 text-sm mb-3">Desde cero, ideal para empezar.</p>
      <span class="text-sm font-semibold">Desde 300€</span>
    </div>

    <!-- 2 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Volumen ruso</h3>
      <p class="text-gray-600 text-sm mb-3">Técnicas avanzadas de volumen.</p>
      <span class="text-sm font-semibold">Desde 500€</span>
    </div>

    <!-- 3 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Lifting de pestañas</h3>
      <p class="text-gray-600 text-sm mb-3">
        Resultados naturales y duraderos.
      </p>
      <span class="text-sm font-semibold">Consultar</span>
    </div>

    <!-- 4 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Laminado de cejas</h3>
      <p class="text-gray-600 text-sm mb-3">Diseño y fijación profesional.</p>
      <span class="text-sm font-semibold">Consultar</span>
    </div>

    <!-- 5 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Pack completo</h3>
      <p class="text-gray-600 text-sm mb-3">
        Formación completa + técnicas avanzadas.
      </p>
      <span class="text-sm font-semibold">Desde 900€</span>
    </div>

    <!-- 6 -->
    <div class="bg-white p-6 rounded-2xl shadow-sm hover:shadow-md transition">
      <div class="h-40 bg-gray-200 rounded-xl mb-4"></div>
      <h3 class="font-semibold mb-2">Masterclass</h3>
      <p class="text-gray-600 text-sm mb-3">Perfeccionamiento intensivo.</p>
      <span class="text-sm font-semibold">Consultar</span>
    </div>
  </div>
</section>

<!-- BENEFICIOS -->
<section class="bg-gray-50 py-20 px-6 text-center">
  <h2 class="text-3xl font-semibold mb-10">¿Por qué formarte con nosotros?</h2>

  <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
    <div>
      <h3 class="font-semibold mb-2">100% práctico</h3>
      <p class="text-gray-600 text-sm">
        Aprendes trabajando desde el primer día.
      </p>
    </div>

    <div>
      <h3 class="font-semibold mb-2">Experiencia real</h3>
      <p class="text-gray-600 text-sm">
        Más de 20 años formando profesionales.
      </p>
    </div>

    <div>
      <h3 class="font-semibold mb-2">Alta rentabilidad</h3>
      <p class="text-gray-600 text-sm">Convierte tu formación en ingresos.</p>
    </div>
  </div>
</section>
