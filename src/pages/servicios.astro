---
import Layout from "../layouts/Layout.astro";

const pestanas = [
  {
    name: "Lifting de pestañas con tinte",
    desc: "Eleva y curva las pestañas desde la raíz.",
    pro: "50€",
    student: "35€",
  },
  {
    name: "Lifting coreano",
    desc: "Nutrición profunda y acabado natural.",
    pro: "55€",
    student: "40€",
  },
  {
    name: "Pestañas pelo a pelo",
    desc: "Resultado natural y elegante.",
    pro: "70€",
    student: "50€",
  },
  {
    name: "Pestañas clásicas",
    desc: "Longitud y definición sutil.",
    pro: "65€",
    student: "45€",
  },
  {
    name: "Volumen",
    desc: "Mayor densidad e intensidad.",
    pro: "80€",
    student: "55€",
  },
  {
    name: "Volumen ruso",
    desc: "Máxima densidad y glamour.",
    pro: "95€",
    student: "70€",
  },
];

const cejas = [
  {
    name: "Laminado de cejas con tinte",
    desc: "Cejas definidas, voluminosas y peinadas.",
    pro: "45€",
    student: "30€",
  },
  {
    name: "Tinte de cejas",
    desc: "Intensifica el color y define.",
    pro: "15€",
    student: "10€",
  },
  {
    name: "Epilación de cejas",
    desc: "Hilo, cera o pinza.",
    pro: "12€",
    student: "8€",
  },
  {
    name: "Diseño de cejas",
    desc: "Visagismo personalizado.",
    pro: "20€",
    student: "15€",
  },
];
---

<Layout
  title="Precios de cejas y pestañas en Madrid | Lashes Esmera"
  description="Servicios profesionales de cejas y pestañas en Madrid. Consulta precios y reserva fácilmente."
  canonical="https://lashesesmera.com/servicios"
>

  <!-- HEADER -->
  <section class="bg-gray-50 pt-16 pb-14 px-6 text-center border-b border-gray-100">
    <p class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-4">Estudio en Madrid</p>
    <h1 class="text-3xl md:text-4xl font-semibold tracking-tight mb-4">Servicios y precios</h1>
    <p class="text-gray-500 text-sm max-w-md mx-auto mb-8 leading-relaxed">
      Resultados personalizados para realzar tu mirada. Reserva tu cita directamente por WhatsApp.
    </p>
    <a
      href="https://wa.me/34600000000"
      class="inline-flex items-center gap-2 bg-black text-white px-8 py-3 rounded-full text-sm font-medium hover:bg-gray-800 transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
      </svg>
      Reservar por WhatsApp
    </a>
  </section>


  <!-- TABLAS DE PRECIOS -->
  <section class="py-20 px-6 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-10">

      <!-- PESTAÑAS -->
      <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
        <h2 class="text-xl font-semibold mb-8 pb-4 border-b border-gray-100">Pestañas</h2>

        <!-- CABECERA -->
        <div class="grid grid-cols-[1fr_150px] text-xs text-gray-400 uppercase tracking-widest pb-3 mb-2">
          <span>Servicio</span>
          <div class="grid grid-cols-2 text-right gap-4">
            <span>Profesional</span>
            <span>Alumno</span>
          </div>
        </div>

        <div class="space-y-5">
          {pestanas.map((s) => (
            <div class="grid grid-cols-[1fr_150px] gap-4 py-4 border-b border-dashed border-gray-100 last:border-0">
              <div>
                <p class="font-medium text-sm">{s.name}</p>
                <p class="text-xs text-gray-400 mt-0.5">{s.desc}</p>
              </div>
              <div class="grid grid-cols-2 gap-4 text-right text-sm">
                <span class="font-medium">{s.pro}</span>
                <span class="text-gray-400">{s.student}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CEJAS -->
      <div class="bg-white rounded-2xl border border-gray-100 p-8 shadow-sm">
        <h2 class="text-xl font-semibold mb-8 pb-4 border-b border-gray-100">Cejas</h2>

        <!-- CABECERA -->
        <div class="grid grid-cols-[1fr_150px] text-xs text-gray-400 uppercase tracking-widest pb-3 mb-2">
          <span>Servicio</span>
          <div class="grid grid-cols-2 text-right gap-4">
            <span>Profesional</span>
            <span>Alumno</span>
          </div>
        </div>

        <div class="space-y-5">
          {cejas.map((s) => (
            <div class="grid grid-cols-[1fr_150px] gap-4 py-4 border-b border-dashed border-gray-100 last:border-0">
              <div>
                <p class="font-medium text-sm">{s.name}</p>
                <p class="text-xs text-gray-400 mt-0.5">{s.desc}</p>
              </div>
              <div class="grid grid-cols-2 gap-4 text-right text-sm">
                <span class="font-medium">{s.pro}</span>
                <span class="text-gray-400">{s.student}</span>
              </div>
            </div>
          ))}
        </div>

        <!-- NOTA -->
        <p class="mt-8 text-xs text-gray-400 leading-relaxed bg-gray-50 rounded-xl p-4">
          Los precios de alumno aplican durante las sesiones de práctica supervisada. Consulta disponibilidad.
        </p>
      </div>

    </div>
  </section>


  <!-- CTA RESERVA -->
  <section class="bg-[#f1cdf0] py-20 px-6 text-center">
    <div class="max-w-lg mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] text-gray-600 mb-5">¿Lista para reservar?</p>
      <h2 class="text-3xl md:text-4xl font-semibold mb-5 leading-tight tracking-tight">
        Reserva tu cita en Madrid
      </h2>
      <p class="mb-10 text-gray-700 leading-relaxed">
        Atención personalizada · Resultados profesionales · Respuesta rápida
      </p>
      <a
        href="https://wa.me/34600000000"
        class="inline-flex items-center gap-2 bg-black text-white px-10 py-3.5 rounded-full text-sm font-medium hover:bg-gray-800 transition"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
        </svg>
        Reservar por WhatsApp
      </a>
    </div>
  </section>


  <!-- FORMACIÓN -->
  <section class="py-24 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

      <div class="overflow-hidden rounded-2xl shadow-sm">
        <img
          src="/services/formacion.png"
          alt="Curso de cejas y pestañas en Madrid"
          class="w-full h-[400px] object-cover hover:scale-[1.03] transition duration-700"
        />
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-5">Formación Profesional</p>
        <h2 class="text-3xl md:text-4xl font-semibold mb-5 leading-tight tracking-tight">
          ¿Quieres formarte con nosotros?
        </h2>
        <p class="text-gray-600 mb-7 leading-relaxed">
          Aprende técnicas profesionales de cejas y pestañas con formación práctica, seguimiento real y resultados desde el primer día.
        </p>
        <ul class="space-y-3 mb-10">
          {[
            "Formación presencial y online",
            "Técnicas actualizadas y reales",
            "Acompañamiento personalizado",
          ].map((item) => (
            <li class="flex items-center gap-3 text-sm text-gray-700">
              <span class="w-1.5 h-1.5 rounded-full bg-black flex-shrink-0"></span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="/formacion"
          class="bg-black text-white px-9 py-3.5 rounded-full text-sm font-medium tracking-wide hover:bg-gray-800 transition inline-block"
        >
          Ver formaciones
        </a>
        <p class="mt-4 text-xs text-gray-400">Plazas limitadas · Grupos reducidos</p>
      </div>
    </div>
  </section>

</Layout>
