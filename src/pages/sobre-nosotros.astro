---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Sobre Lashes Esmera | Especialistas en cejas y pestañas"
  description="Conoce Lashes Esmera, especialistas en cejas y pestañas con más de 20 años de experiencia en formación y estética profesional en Madrid."
  canonical="https://lashesesmera.com/sobre-nosotros"
>
  <section
    class="relative h-[60vh] md:h-[70vh] flex items-center justify-center text-center overflow-hidden"
  >
    <!-- IMAGEN -->
    <img
      src="/nosotros/hero.png"
      alt="Lashes Esmera"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />

    <!-- OVERLAY -->
    <div class="absolute inset-0 bg-black/70"></div>

    <!-- CONTENIDO -->
    <div class="relative z-10 px-6 max-w-2xl text-white">
      <h1 class="text-4xl md:text-6xl font-semibold mb-4 leading-tight">
        Más que estética,<br /> una especialización
      </h1>

      <p class="text-lg md:text-xl opacity-90 mb-6">
        Más de 20 años formando profesionales en cejas y pestañas en Madrid.
      </p>
    </div>
  </section>

  <!-- HISTORIA -->
  <section class="py-24 px-6 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- IMAGEN (MISMO ESTILO) -->
      <div class="flex justify-center md:justify-start">
        <div
          class="bg-white/60 backdrop-blur-md border border-gray-200 rounded-3xl shadow-xl"
        >
          <img
            src="/nosotros/centro.png"
            alt="Estudio Lashes Esmera"
            class="rounded-2xl object-cover w-full h-[420px]"
          />
        </div>
      </div>

      <!-- TEXTO -->
      <div>
        <h2 class="text-3xl font-semibold mb-4">Nuestra historia</h2>

        <p class="text-gray-600 mb-4">
          Lashes Esmera nace como una evolución de Esmera School con más de 20
          años de experiencia.
        </p>

        <p class="text-gray-600 mb-4">
          Tras formar a cientos de profesionales, decidimos crear una marca
          especializada.
        </p>

        <p class="text-gray-600">
          Hoy combinamos formación, servicios y productos en un mismo concepto.
        </p>

        <div
          class="mt-6 inline-block bg-white px-5 py-2 rounded-full text-sm text-gray-600 shadow-md border"
        >
          +20 años de experiencia
        </div>
      </div>
    </div>
  </section>

  <!-- FILOSOFÍA -->
  <section class="bg-gray-50 py-24 px-6 text-center">
    <h2 class="text-3xl font-semibold mb-12">Nuestra filosofía</h2>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      <div
        class="bg-white p-6 rounded-2xl shadow-md hover:shadow-2xl transition"
      >
        <div class="mb-3 text-pink-500 text-xl">✨</div>
        <h3 class="font-semibold mb-2">Especialización</h3>
        <p class="text-gray-600 text-sm">Solo trabajamos cejas y pestañas.</p>
      </div>

      <div
        class="bg-white p-6 rounded-2xl shadow-md hover:shadow-2xl transition"
      >
        <div class="mb-3 text-pink-500 text-xl">💎</div>
        <h3 class="font-semibold mb-2">Calidad</h3>
        <p class="text-gray-600 text-sm">Técnicas y productos profesionales.</p>
      </div>

      <div
        class="bg-white p-6 rounded-2xl shadow-md hover:shadow-2xl transition"
      >
        <div class="mb-3 text-pink-500 text-xl">🏆</div>
        <h3 class="font-semibold mb-2">Experiencia</h3>
        <p class="text-gray-600 text-sm">
          Más de 20 años formando profesionales.
        </p>
      </div>
    </div>
  </section>

  <!-- FUNDADORA -->
  <section class="py-24 px-6 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- TEXTO -->
      <div>
        <h2 class="text-3xl font-semibold mb-2">Bertha Taborda</h2>

        <p class="text-sm text-gray-400 mb-4">
          Fundadora · +20 años de experiencia
        </p>

        <p class="text-gray-600 mb-4">
          Fundadora de Esmera School y creadora de Lashes Esmera.
        </p>

        <p class="text-gray-600 mb-4">
          Su misión ha sido formar profesionales reales.
        </p>

        <p class="text-gray-600">
          Hoy lidera este proyecto enfocado en elevar el sector.
        </p>

        <div
          class="mt-6 inline-block bg-white px-5 py-2 rounded-full text-sm text-gray-600 shadow-md border"
        >
          Referente en formación estética
        </div>
      </div>

      <!-- IMAGEN (MISMO ESTILO) -->
      <div class="flex justify-center md:justify-end">
        <div
          class="bg-white/60 backdrop-blur-md border border-gray-200 rounded-3xl shadow-xl"
        >
          <img
            src="/nosotros/directora.png"
            alt="Bertha Taborda"
            class="w-auto max-h-[420px] object-contain rounded-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- PODIO -->
  <section class="bg-gray-50 py-32 px-6 text-center">
    <h2 class="text-3xl font-semibold mb-20">Lo que nos diferencia</h2>

    <div
      class="max-w-5xl mx-auto flex flex-col md:flex-row items-end justify-center gap-6"
    >
      <!-- 2º -->
      <div
        class="bg-white rounded-2xl shadow-lg w-full md:w-1/3 h-[220px] flex flex-col justify-center items-center relative"
      >
        <div
          class="absolute -top-6 bg-gray-200 text-gray-700 text-sm px-4 py-1 rounded-full shadow"
        >
          🥈 2º
        </div>
        <h3 class="font-semibold mb-2 mt-4">Enfoque profesional</h3>
        <p class="text-gray-600 text-sm px-4">
          Preparación real para trabajar o emprender.
        </p>
      </div>

      <!-- 1º -->
      <div
        class="bg-white rounded-2xl shadow-2xl w-full md:w-1/3 h-[280px] flex flex-col justify-center items-center relative scale-105 border border-pink-200"
      >
        <div
          class="absolute -top-8 bg-pink-500 text-white text-sm px-5 py-2 rounded-full shadow-lg font-semibold"
        >
          🥇 Nº1
        </div>
        <h3 class="font-semibold mb-2 mt-6 text-lg">Formación real</h3>
        <p class="text-gray-600 text-sm px-6">
          Resultados desde el primer día con práctica real.
        </p>
      </div>

      <!-- 3º -->
      <div
        class="bg-white rounded-2xl shadow-md w-full md:w-1/3 h-[200px] flex flex-col justify-center items-center relative"
      >
        <div
          class="absolute -top-6 bg-gray-200 text-gray-700 text-sm px-4 py-1 rounded-full shadow"
        >
          🥉 3º
        </div>
        <h3 class="font-semibold mb-2 mt-4">Marca especializada</h3>
        <p class="text-gray-600 text-sm px-4">
          100% enfocada en cejas y pestañas.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-20 px-6 text-center border-t">
    <h2 class="text-3xl font-semibold mb-4">¿Qué te gustaría hacer ahora?</h2>

    <p class="text-gray-600 mb-8">
      Descubre nuestros servicios, fórmate o consulta nuestros productos.
    </p>

    <div class="flex flex-col md:flex-row justify-center gap-4">
      <a
        href="/servicios"
        class="bg-black text-white px-8 py-3 rounded-full font-semibold hover:bg-gray-800 transition shadow-md hover:shadow-xl"
      >
        Ver servicios
      </a>

      <a
        href="/formacion"
        class="border border-black px-8 py-3 rounded-full font-semibold hover:bg-black hover:text-white transition"
      >
        Formación
      </a>

      <a
        href="/tienda"
        class="border border-gray-300 px-8 py-3 rounded-full font-semibold hover:bg-gray-100 transition"
      >
        Tienda
      </a>
    </div>
  </section>
</Layout>
