---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Precios de cejas y pestañas en Madrid | Lashes Esmera"
  description="Servicios profesionales de cejas y pestañas en Madrid. Consulta precios y reserva fácilmente."
  canonical="https://lashesesmera.com/servicios"
>
  <!-- SERVICIOS -->
  <section class="pt-24 px-6 max-w-6xl mx-auto">
    <div class="mb-16 text-center">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight">
        Servicios y precios
      </h2>
      <p class="text-gray-500 text-sm mt-0">
        Resultados personalizados para realzar tu mirada
      </p>
      <div class="mt-4 text-center">
        <a
          href="https://wa.me/34600000000"
          class="inline-flex items-center gap-2 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-8 py-3 rounded-full text-sm md:text-base font-semibold transition-all duration-300 shadow-md hover:shadow-xl hover:scale-[1.02]"
        >
          <!-- ICONO -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
          </svg>
      
          Reservar por WhatsApp
        </a>
      </div>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- PESTAÑAS -->
      <div>
        <h3 class="text-xl font-semibold mb-6">Pestañas</h3>

        <!-- CABECERA -->
        <div
          class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_140px] gap-4 text-sm text-gray-400 border-b pb-2 mb-4"
        >
          <span></span>
          <div class="grid grid-cols-2 gap-4 md:gap-6 text-right">
            <span>Profesional</span>
            <span class="text-gray-500">Alumno</span>
          </div>
        </div>

        <div class="space-y-6">
          {
            [
              {
                name: "Lifting de pestañas con tinte",
                desc: "Eleva y curva las pestañas desde la raíz.",
                pro: "50€",
                student: "35€",
              },
              {
                name: "Lifting coreano",
                desc: "Nutrición profunda y acabado natural.",
                pro: "55€",
                student: "40€",
              },
              {
                name: "Pestañas pelo a pelo",
                desc: "Resultado natural y elegante.",
                pro: "70€",
                student: "50€",
              },
              {
                name: "Pestañas clásicas",
                desc: "Longitud y definición sutil.",
                pro: "65€",
                student: "45€",
              },
              {
                name: "Volumen",
                desc: "Mayor densidad e intensidad.",
                pro: "80€",
                student: "55€",
              },
              {
                name: "Volumen ruso",
                desc: "Máxima densidad y glamour.",
                pro: "95€",
                student: "70€",
              },
            ].map((s) => (
              <div class="border-b border-dashed pb-4">
                <div class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_140px] gap-4">
                  <div>
                    <p class="font-medium">{s.name}</p>
                    <p class="text-sm text-gray-500">{s.desc}</p>
                  </div>

                  <div class="grid grid-cols-2 gap-4 md:gap-6 text-right text-sm whitespace-nowrap">
                    <span class="text-gray-500">{s.pro}</span>
                    <span class="text-gray-600">{s.student}</span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- CEJAS -->
      <div>
        <h3 class="text-xl font-semibold mb-6">Cejas</h3>

        <div
          class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_140px] gap-4 text-sm text-gray-400 border-b pb-2 mb-4"
        >
          <span></span>
          <div class="grid grid-cols-2 gap-4 md:gap-6 text-right">
            <span>Profesional</span>
            <span class="text-gray-500">Alumno</span>
          </div>
        </div>

        <div class="space-y-6">
          {
            [
              {
                name: "Laminado de cejas con tinte",
                desc: "Cejas definidas, voluminosas y peinadas.",
                pro: "45€",
                student: "30€",
              },
              {
                name: "Tinte de cejas",
                desc: "Intensifica el color y define.",
                pro: "15€",
                student: "10€",
              },
              {
                name: "Epilación de cejas",
                desc: "Hilo, cera o pinza.",
                pro: "12€",
                student: "8€",
              },
              {
                name: "Diseño de cejas",
                desc: "Visagismo personalizado.",
                pro: "20€",
                student: "15€",
              },
            ].map((s) => (
              <div class="border-b border-dashed pb-4">
                <div class="grid grid-cols-[1fr_auto] md:grid-cols-[1fr_140px] gap-4">
                  <div>
                    <p class="font-medium">{s.name}</p>
                    <p class="text-sm text-gray-500">{s.desc}</p>
                  </div>

                  <div class="grid grid-cols-2 gap-4 md:gap-6 text-right text-sm whitespace-nowrap">
                    <span class="text-gray-500">{s.pro}</span>
                    <span class="text-gray-600">{s.student}</span>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="w-full overflow-hidden leading-none mb-0 sm:-mb-20">
    <img src="/dividers/wave.svg" class="w-full block" alt="divider" />
  </div>

  <!-- CTA -->
  <section class="bg-rose-50 pt-20 pb-24 text-center px-6">
    <div class="max-w-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-semibold mb-4 text-gray-900">
        Reserva tu cita
      </h2>

      <p class="mb-8 text-gray-600">
        Resultados profesionales en Madrid · Citas limitadas esta semana
      </p>

      <div class="mt-4 text-center">
        <a
          href="https://wa.me/34600000000"
          class="inline-flex items-center gap-2 bg-gradient-to-r from-green-500 to-green-600 hover:from-green-600 hover:to-green-700 text-white px-8 py-3 rounded-full text-sm md:text-base font-semibold transition-all duration-300 shadow-md hover:shadow-xl hover:scale-[1.02]"
        >
          <!-- ICONO -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
          </svg>
      
          Reservar por WhatsApp
        </a>
      </div>

      <p class="mt-4 text-xs text-gray-400">
        Respuesta rápida · Atención personalizada
      </p>
    </div>
  </section>

  <!-- FORMACIÓN -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <!-- IMAGEN -->
      <div class="relative">
        <img
          src="/services/formacion.png"
          alt="Curso de cejas y pestañas"
          class="rounded-2xl object-cover w-full h-[400px]"
        />

        <!-- Overlay sutil -->
        <div class="absolute inset-0 bg-black/10 rounded-2xl"></div>
      </div>

      <!-- TEXTO -->
      <div class="text-center md:text-left">
        <h2
          class="text-3xl md:text-4xl font-semibold mb-4 text-gray-900 leading-tight"
        >
          ¿Quieres formarte con nosotros?
        </h2>

        <p class="text-gray-600 mb-6">
          Aprende técnicas profesionales de cejas y pestañas con formación
          práctica, seguimiento real y resultados desde el primer día.
        </p>

        <!-- BENEFICIOS -->
        <div class="space-y-3 mb-8 text-sm text-gray-600">
          <p>✔ Formación presencial y online</p>
          <p>✔ Técnicas actualizadas y reales</p>
          <p>✔ Acompañamiento personalizado</p>
        </div>

        <!-- CTA -->
        <a
          href="/formacion"
          class="inline-block bg-gradient-to-r from-gray-900 to-black hover:opacity-90 text-white px-10 py-4 rounded-full font-semibold transition shadow-md hover:shadow-xl"
        >
          Ver formaciones
        </a>

        <p class="mt-4 text-xs text-gray-400">
          Plazas limitadas · Grupos reducidos
        </p>
      </div>
    </div>
  </section>
</Layout>
