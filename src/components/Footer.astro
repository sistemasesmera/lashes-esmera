---
import { Image } from "astro:assets";
import logo from "../assets/logo-blanco.png";
const currentYear = new Date().getFullYear();
---

<footer class="bg-white border-t border-gray-100">
  <!-- CONTENIDO -->
  <div
    class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-3 gap-12 items-start"
  >
    <!-- MARCA -->
    <div
      class="flex flex-col items-center md:items-start text-center md:text-left"
    >
      <Image src={logo} alt="Lashes Esmera" width={70} height={70} />

      <p class="mt-6 text-gray-600 leading-relaxed max-w-xs">
        Especialistas en cejas y pestañas en Madrid. Formación, servicios y
        productos profesionales para lash artists.
      </p>
    </div>

    <!-- NAVEGACIÓN -->
    <div class="flex flex-col items-center text-center">
      <h4 class="text-sm font-semibold tracking-wide mb-5 text-black">
        NAVEGACIÓN
      </h4>

      <ul class="space-y-3 text-gray-600 text-sm">
        <li><a href="/" class="hover:text-black transition">Inicio</a></li>
        <li>
          <a href="/servicios" class="hover:text-black transition">Servicios</a>
        </li>
        <li>
          <a href="/formacion" class="hover:text-black transition">Formación</a>
        </li>
        <li>
          <a href="/sobre-nosotros" class="hover:text-black transition"
            >Nosotros</a
          >
        </li>
        <li>
          <a href="/contacto" class="hover:text-black transition">Contacto</a>
        </li>
      </ul>
    </div>

    <!-- CONTACTO -->
    <div
      class="flex flex-col items-center md:items-end text-center md:text-right"
    >
      <h4 class="text-sm font-semibold tracking-wide mb-5 text-black">
        CONTACTO
      </h4>

      <p class="text-gray-600 text-sm">Madrid, España</p>

      <a
        href="tel:+34600000000"
        class="mt-3 text-sm hover:text-black transition"
      >
        +34 600 00 00 00
      </a>

      <a
        href="mailto:info@lashesesmera.com"
        class="text-sm hover:text-black transition"
      >
        info@lashesesmera.com
      </a>

      <!-- CTA -->
      <a
        href="https://wa.me/34600000000"
        class="mt-6 inline-block bg-black text-white px-6 py-2 rounded-full text-xs tracking-wide hover:bg-gray-800 transition"
      >
        RESERVAR POR WHATSAPP
      </a>
    </div>
  </div>

  <!-- DIVISOR -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-t border-gray-100"></div>
  </div>

  <!-- FOOTER BOTTOM -->
  <div
    class="max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500"
  >
    <p>
      © {currentYear} Lashes Esmera. Todos los derechos reservados.
    </p>

    <div class="flex gap-4">
      <a href="/politica-privacidad" class="hover:text-black transition"
        >Privacidad</a
      >
      <a href="/terminos" class="hover:text-black transition">Términos</a>
      <a href="/aviso-legal" class="hover:text-black transition">Legal</a>
    </div>
  </div>
</footer>
