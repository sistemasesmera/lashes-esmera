---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Lashes Esmera | Formación, servicios y productos de cejas y pestañas en Madrid"
  description="Especialistas en cejas y pestañas en Madrid. Formación profesional, servicios de estudio y productos para lash artists."
  canonical="https://lashesesmera.com/"
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-white">

    <!-- Fondo decorativo: blob suave en esquina superior derecha -->
    <div
      class="pointer-events-none absolute top-0 right-0 w-[55%] h-full -z-0"
      style="background: radial-gradient(ellipse 80% 80% at 85% 30%, rgba(241,205,240,0.18) 0%, transparent 70%);"
    ></div>
    <!-- Línea decorativa vertical -->
    <div class="pointer-events-none absolute top-0 left-[50%] hidden lg:block w-px h-full bg-gradient-to-b from-transparent via-[#f1cdf0]/20 to-transparent -z-0"></div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
      <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-20 items-center">

        <!-- COLUMNA IZQUIERDA: Texto -->
        <div>
          <div class="hero-eyebrow flex items-center gap-3 mb-8">
            <span class="block w-7 h-px bg-[#c9a0c7]"></span>
            <p class="text-[10.5px] uppercase tracking-[0.42em] text-[#b89fb7] font-medium">
              Madrid · Especialistas en mirada
            </p>
          </div>

          <h1 class="hero-h1 text-[clamp(3rem,6.5vw,5.2rem)] font-bold leading-[1.0] tracking-tight mb-8" style="color: #2d1229;">
            La mirada<br/>
            <em class="not-italic font-light" style="color: #c9a0c7;">que te</em><br/>
            diferencia.
          </h1>

          <p class="hero-p text-base leading-relaxed mb-10 max-w-[340px]" style="color: #9c7a9a;">
            Formación profesional, servicios especializados y productos para lash artists en Madrid.
          </p>

          <div class="hero-ctas flex flex-wrap gap-3.5">
            <a
              href="/formacion"
              class="text-white px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide transition-all duration-200 hover:scale-105"
              style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 20px rgba(156,90,150,0.25);"
            >
              Ver formación
            </a>
            <a
              href="https://wa.me/34600000000"
              class="px-9 py-3.5 rounded-full text-sm font-medium tracking-wide transition-all duration-200 hover:scale-105"
              style="border: 1.5px solid rgba(201,160,199,0.5); color: #7a4a78;"
              onmouseover="this.style.background='#fdf0fd'; this.style.borderColor='#c9a0c7';"
              onmouseout="this.style.background=''; this.style.borderColor='rgba(201,160,199,0.5)';"
            >
              Reservar cita
            </a>
          </div>

        </div>

        <!-- COLUMNA DERECHA: Imagen contenida -->
        <div class="hero-image relative hidden lg:flex items-center justify-center">
          <!-- Fondo rosa sólido desplazado (efecto editorial) -->
          <div
            class="absolute rounded-[2rem]"
            style="inset: 0; transform: translate(14px, 18px); background-color: #f1cdf0; opacity: 0.45; z-index: 0;"
          ></div>

          <!-- Imagen contenida (no es fondo) -->
          <div class="relative rounded-[2rem] overflow-hidden w-full" style="aspect-ratio: 3/4; z-index: 1;">
            <img
              src="/nosotros/hero.png"
              alt="Estudio Lashes Esmera Madrid"
              class="w-full h-full object-cover object-center hover:scale-[1.04] transition-transform duration-700"
            />
            <!-- Degradado sutil en base -->
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.12) 0%, transparent 50%);"></div>
          </div>

          <!-- Tarjeta flotante inferior-izquierda -->
          <div
            class="absolute z-10 bg-white rounded-xl px-5 py-3.5 border border-black/5"
            style="bottom: -14px; left: -24px; box-shadow: 0 8px 36px rgba(0,0,0,0.10);"
          >
            <p class="text-[9.5px] uppercase tracking-[0.3em] text-gray-400 mb-0.5">Centro de referencia</p>
            <p class="text-sm font-bold text-[#0a0a0a]">Madrid, España</p>
          </div>

          <!-- Badge superior-derecha -->
          <div
            class="absolute z-10 flex items-center gap-1.5 rounded-full pl-3 pr-4 py-2"
            style="top: -12px; right: -16px; font-size: 11px; font-weight: 600; letter-spacing: 0.04em; background: #f1cdf0; color: #5c2d5a;"
          >
            <span style="width:6px;height:6px;border-radius:9999px;background:#9c5a96;flex-shrink:0;display:inline-block;"></span>
            Estudio abierto
          </div>
        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero-scroll-indicator absolute bottom-6 left-1/2 -translate-x-1/2 z-10">
      <div class="hero-scroll-inner flex flex-col items-center">
        <div class="hero-scroll-line w-px h-10 bg-black/12"></div>
      </div>
    </div>
  </section>


  <!-- ─── STATS ─────────────────────────────────────────────────── -->
  <section id="stats-section" style="background: #f7f2f7;">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 divide-x divide-black/6">
      {[
        { num: 20,  prefix: "+", label: "Años de experiencia" },
        { num: 500, prefix: "+", label: "Alumnas formadas" },
        { num: 5,   prefix: "",  label: "Técnicas especializadas" },
        { num: 1,   prefix: "",  label: "Estudio en Madrid" },
      ].map((s, i) => (
        <div
          data-animate
          data-delay={String(i * 120)}
          class="flex flex-col items-center justify-center text-center py-10 px-4"
        >
          <span
            class="count-num text-3xl md:text-4xl font-bold tracking-tight"
            style="color: #2d1229;"
            data-count={String(s.num)}
            data-prefix={s.prefix}
          >{s.prefix}0</span>
          <span class="text-[10px] uppercase tracking-widest mt-2 leading-tight max-w-[90px]" style="color: #b89fb7;">{s.label}</span>
        </div>
      ))}
    </div>
  </section>


  <!-- ─── FORMACIÓN ─────────────────────────────────────────────── -->
  <section class="py-32 px-6 overflow-hidden">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[1fr_1.15fr] gap-16 items-center">

      <div data-animate="left">
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-7" style="color: #b89fb7;">Formación Profesional</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.05] tracking-tight mb-8" style="color: #2d1229;">
          Aprende con<br/>las mejores<br/>del sector
        </h2>
        <p class="leading-relaxed mb-8 max-w-sm" style="color: #9c7a9a;">
          Más de 20 años formando lash artists en Madrid. Práctica real desde el primer día y certificado profesional incluido.
        </p>

        <ul class="space-y-5 mb-10">
          {[
            "Certificado profesional incluido",
            "Modelos reales desde el primer día",
            "Modalidad presencial y online",
            "Grupos reducidos y personalizados",
          ].map((item, i) => (
            <li
              data-animate
              data-delay={String(100 + i * 100)}
              class="flex items-center gap-4 text-sm"
              style="color: #5c2d5a;"
            >
              <span class="w-6 h-px flex-shrink-0 block" style="background: #c9a0c7;"></span>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="/formacion"
          class="text-white px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:scale-105 transition-all duration-200 inline-block"
          style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 20px rgba(156,90,150,0.22);"
        >
          Ver cursos disponibles
        </a>
      </div>

      <div data-animate="right" class="overflow-hidden rounded-2xl">
        <img
          src="/services/formacion.png"
          alt="Formación profesional de cejas y pestañas Madrid"
          class="w-full h-[540px] object-cover hover:scale-[1.04] transition duration-700"
        />
      </div>

    </div>
  </section>


  <!-- ─── SERVICIOS ───────────────────────────────────────────── -->
  <section style="background: #f4eef4;" class="py-32 px-6 overflow-hidden">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

      <div data-animate="left" class="overflow-hidden rounded-2xl order-2 md:order-1">
        <img
          src="/nosotros/centro.png"
          alt="Estudio Lashes Esmera Madrid"
          class="w-full h-[520px] object-cover hover:scale-[1.04] transition duration-700"
        />
      </div>

      <div data-animate="right" class="order-1 md:order-2">
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-7" style="color: #b89fb7;">Estudio en Madrid</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold text-[#0a0a0a] leading-[1.05] tracking-tight mb-8">
          Servicios<br/>profesionales
        </h2>
        <p class="text-[#777] text-sm leading-relaxed mb-10 max-w-sm">
          Extensiones de pestañas, lifting, laminado y diseño de cejas. Técnicas actualizadas, productos de alta gama y resultados que hablan por sí solos.
        </p>

        <div class="mb-10">
          {[
            { name: "Lifting de pestañas",       price: "desde 50€" },
            { name: "Extensiones volumen ruso",  price: "desde 95€" },
            { name: "Laminado de cejas",          price: "desde 45€" },
            { name: "Diseño de cejas",            price: "desde 20€" },
          ].map((s, i) => (
            <div
              data-animate
              data-delay={String(i * 100)}
              class="flex justify-between items-center py-4 border-b border-black/6"
            >
              <span class="text-[#333] text-sm font-medium">{s.name}</span>
              <span class="text-[#aaa] text-sm tabular-nums">{s.price}</span>
            </div>
          ))}
        </div>

        <a
          href="/servicios"
          class="bg-[#0a0a0a] text-white px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:bg-[#222] hover:scale-105 transition-all duration-200 inline-block"
        >
          Ver todos los precios
        </a>
      </div>

    </div>
  </section>


  <!-- ─── TESTIMONIOS ─────────────────────────────────────────── -->
  <section class="py-32 px-6 bg-white overflow-hidden">
    <div class="max-w-6xl mx-auto">

      <div data-animate class="text-center mb-16">
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-4" style="color: #c9a0c7;">Reseñas</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.2rem)] font-bold tracking-tight leading-tight" style="color: #2d1229;">
          Lo que dicen<br/>nuestras clientas
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            name: "María G.",
            service: "Extensiones volumen ruso",
            text: "Llevaba años queriendo hacerme extensiones y aquí encontré exactamente lo que buscaba. El resultado duró muchísimo más de lo esperado. Volveré siempre.",
            color: "#fdf6fd",
          },
          {
            name: "Laura M.",
            service: "Curso lifting de pestañas",
            text: "El curso superó todas mis expectativas. Práctica real desde el primer día y Bertha es una profesional increíble. Ahora trabajo en mi propio centro.",
            color: "#f4eef4",
            featured: true,
          },
          {
            name: "Ana L.",
            service: "Laminado de cejas",
            text: "Por fin un sitio donde entienden que las cejas enmarcan la cara. El resultado fue natural y perfecto para mi tipo de cara. Totalmente recomendado.",
            color: "#fdf6fd",
          },
          {
            name: "Carmen R.",
            service: "Lifting coreano",
            text: "Vine recomendada por una amiga y no me puedo creer el cambio. Muy cómodo y el resultado es espectacular. Todas mis amigas ya me han preguntado dónde fui.",
            color: "#f4eef4",
          },
        ].map((t, i) => (
          <div
            data-animate
            data-delay={String(i * 100)}
            class="flex flex-col p-6 rounded-2xl"
            style={`background: ${t.color}; border: ${t.featured ? '1.5px solid #c9a0c7' : '1px solid rgba(201,160,199,0.18)'};`}
          >
            <!-- Estrellas -->
            <div class="flex gap-0.5 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-3.5 h-3.5" fill="#c9a0c7" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <!-- Texto -->
            <p class="text-sm leading-relaxed flex-1 italic mb-5" style="color: #6b5a6a;">"{t.text}"</p>

            <!-- Autor -->
            <div class="flex items-center gap-3 pt-4" style="border-top: 1px solid rgba(201,160,199,0.2);">
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0" style="background: #f1cdf0; color: #5c2d5a;">
                {t.name.split(' ').map((n: string) => n[0]).join('')}
              </div>
              <div>
                <p class="text-xs font-semibold" style="color: #2d1229;">{t.name}</p>
                <p class="text-[10px]" style="color: #c9a0c7;">{t.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Google Reviews CTA -->
      <div data-animate data-delay="200" class="text-center mt-12">
        <p class="text-sm" style="color: #b89fb7;">
          ¿Has sido clienta? Déjanos tu reseña en
          <a href="https://g.page/r/lashesesmera/review" target="_blank" rel="noopener noreferrer" class="font-medium underline underline-offset-2 transition-colors hover:text-[#9c5a96]" style="color: #9c5a96;">Google</a>
        </p>
      </div>

    </div>
  </section>


  <!-- ─── TIENDA ────────────────────────────────────────────────── -->
  <section class="py-32 px-6" style="background: #fdf6fd;">
    <div class="max-w-5xl mx-auto text-center">

      <div data-animate>
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-6" style="color: #c9a0c7;">Tienda Online</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.2rem)] font-bold tracking-tight leading-tight mb-6" style="color: #2d1229;">
          Material profesional<br/>para lash artists
        </h2>
        <p class="max-w-md mx-auto leading-relaxed mb-16" style="color: #9c7a9a;">
          Pinzas, adhesivos, kits y todo lo que necesitas. Testado y seleccionado por nuestras expertas.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-16 pt-10" style="border-top: 1px solid rgba(201,160,199,0.2);">
        {[
          { title: "Calidad garantizada",   desc: "Testado por profesionales del sector" },
          { title: "Envíos en 24–48 h",     desc: "Entrega rápida en toda España" },
          { title: "Asesoramiento experto", desc: "Te ayudamos a elegir lo mejor" },
        ].map((f, i) => (
          <div data-animate data-delay={String(i * 150)} class="text-center">
            <p class="font-semibold mb-1.5 text-sm" style="color: #5c2d5a;">{f.title}</p>
            <p class="text-sm" style="color: #b89fb7;">{f.desc}</p>
          </div>
        ))}
      </div>

      <div data-animate data-delay="200">
        <a
          href="/tienda"
          class="text-white px-12 py-4 rounded-full text-sm font-semibold tracking-wide hover:scale-105 transition-all duration-200 inline-block"
          style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 20px rgba(156,90,150,0.22);"
        >
          Visitar la tienda →
        </a>
      </div>

    </div>
  </section>


  <!-- ─── CTA FINAL ─────────────────────────────────────────────── -->
  <section class="bg-[#f1cdf0] py-28 px-6">
    <div data-animate class="max-w-xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.38em] font-medium mb-7" style="color: #9c5a96;">Tu nueva carrera te espera</p>
      <h2 class="text-[clamp(2.2rem,5vw,3.5rem)] font-bold mb-7 leading-[1.05] tracking-tight" style="color: #2d1229;">
        Empieza hoy.
      </h2>
      <p class="mb-10 leading-relaxed text-base" style="color: #5c2d5a;">
        Formación, productos y servicios profesionales en un solo lugar.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/formacion"
          class="text-white px-10 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:scale-105 transition-all duration-200"
          style="background: #5c2d5a; box-shadow: 0 4px 16px rgba(92,45,90,0.3);"
        >
          Quiero formarme
        </a>
        <a
          href="https://wa.me/34600000000"
          class="px-10 py-3.5 rounded-full text-sm font-medium tracking-wide hover:scale-105 transition-all duration-200"
          style="border: 1.5px solid #9c5a96; color: #5c2d5a;"
          onmouseover="this.style.background='#9c5a96'; this.style.color='#fff';"
          onmouseout="this.style.background=''; this.style.color='#5c2d5a';"
        >
          Reservar cita
        </a>
      </div>
    </div>
  </section>


<script is:inline>
(function () {
  function easeOutCubic(t) {
    return 1 - Math.pow(1 - t, 3);
  }

  function runCount(el) {
    if (el.dataset.counted) return;
    el.dataset.counted = 'true';

    var target   = parseInt(el.dataset.count, 10);
    var prefix   = el.dataset.prefix || '';
    var duration = 1500;
    var startTs  = null;

    function step(ts) {
      if (!startTs) startTs = ts;
      var progress = Math.min((ts - startTs) / duration, 1);
      el.textContent = prefix + Math.round(easeOutCubic(progress) * target);
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  /* Hero mini-stats: arrancan después de que termine la animación de entrada (~950ms) */
  window.addEventListener('DOMContentLoaded', function () {
    var heroNums = document.querySelectorAll('.hero-stats .count-num');
    heroNums.forEach(function (el, i) {
      setTimeout(function () { runCount(el); }, 950 + i * 120);
    });
  });

  /* Stats section: arrancan al entrar en el viewport */
  var observer = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.count-num').forEach(function (el, i) {
          setTimeout(function () { runCount(el); }, i * 150);
        });
      }
    });
  }, { threshold: 0.35 });

  var statsSection = document.getElementById('stats-section');
  if (statsSection) observer.observe(statsSection);
})();
</script>

</Layout>
