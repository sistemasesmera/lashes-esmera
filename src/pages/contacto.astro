---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contacto Lashes Esmera | Reserva cita o solicita información"
  description="Contacta con Lashes Esmera en Madrid. Reserva tu cita o solicita información sobre nuestros servicios y formación en cejas y pestañas."
  canonical="https://lashesesmera.com/contacto"
/>
  <!-- HERO -->
  <section class="bg-[#f1cdf0] pt-32 pb-20 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-black mb-6">
      Contacto
    </h1>

    <p class="text-lg text-gray-800 max-w-xl mx-auto mb-8">
      Estamos aquí para ayudarte. Escríbenos o visítanos en nuestro centro.
    </p>

    <a 
      href="https://wa.me/34600000000"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Escribir por WhatsApp
    </a>
  </section>

  <!-- INFORMACIÓN -->
  <section class="py-24 px-6 max-w-6xl mx-auto">

    <div class="grid md:grid-cols-3 gap-10 text-center">

      <div>
        <h3 class="font-semibold mb-2">Teléfono</h3>
        <p class="text-gray-600 text-sm">+34 600 00 00 00</p>
      </div>

      <div>
        <h3 class="font-semibold mb-2">Email</h3>
        <p class="text-gray-600 text-sm">info@lashesesmera.com</p>
      </div>

      <div>
        <h3 class="font-semibold mb-2">Ubicación</h3>
        <p class="text-gray-600 text-sm">Madrid, España</p>
      </div>

    </div>

  </section>

  <!-- FORMULARIO -->
  <section class="bg-gray-50 py-24 px-6">

    <div class="max-w-4xl mx-auto text-center mb-10">
      <h2 class="text-3xl font-semibold mb-4">
        Escríbenos
      </h2>

      <p class="text-gray-600">
        Déjanos tu mensaje y te responderemos lo antes posible.
      </p>
    </div>

    <div class="max-w-xl mx-auto">
      <form id="contact-form" class="space-y-5">

        <input
          type="text"
          name="nombre"
          placeholder="Nombre"
          class="w-full px-5 py-3 rounded-full bg-white border border-gray-200 focus:outline-none focus:ring-2 focus:ring-black transition"
          required
        />

        <input
          type="tel"
          name="telefono"
          placeholder="Teléfono"
          class="w-full px-5 py-3 rounded-full bg-white border border-gray-200 focus:outline-none focus:ring-2 focus:ring-black transition"
        />

        <textarea
          name="mensaje"
          placeholder="Escribe tu mensaje..."
          rows="4"
          class="w-full px-5 py-3 rounded-2xl bg-white border border-gray-200 focus:outline-none focus:ring-2 focus:ring-black transition"
          required
        ></textarea>

        <button
          type="submit"
          class="w-full bg-black text-white py-3 rounded-full hover:bg-gray-800 transition text-sm"
        >
          Enviar mensaje
        </button>

      </form>
    </div>

  </section>

  <!-- MAPA (SIMULADO) -->
  <section class="py-24 px-6 max-w-6xl mx-auto">

    <h2 class="text-3xl font-semibold text-center mb-10">
      Dónde estamos
    </h2>

    <div class="w-full h-80 bg-gray-200 rounded-xl flex items-center justify-center">
      <span class="text-gray-500">Mapa (Google Maps aquí)</span>
    </div>

  </section>

  <!-- CTA FINAL -->
  <section class="bg-[#f1cdf0] py-16 px-6 text-center">
    
    <h2 class="text-2xl font-semibold mb-4">
      ¿Prefieres hablar directamente?
    </h2>

    <p class="text-gray-800 mb-6">
      Escríbenos por WhatsApp y te ayudamos al momento.
    </p>

    <a 
      href="https://wa.me/34600000000"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Abrir WhatsApp
    </a>

  </section>

</Layout>

<script is:inline>
  const form = document.getElementById("contact-form");

  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    const data = new FormData(form);

    const nombre = data.get("nombre");
    const telefono = data.get("telefono");
    const mensaje = data.get("mensaje");

    const texto = `Hola, contacto desde la web:

Nombre: ${nombre}
Teléfono: ${telefono}
Mensaje: ${mensaje}`;

    const url = `https://wa.me/34600000000?text=${encodeURIComponent(texto)}`;

    window.open(url, "_blank");
  });
</script>