---
import { Image } from "astro:assets";
import logo from "../assets/logo-blanco.png";
const currentYear = new Date().getFullYear();
---

<footer style="background: #1a0a18; color: #fff;">

  <!-- CONTENIDO PRINCIPAL -->
  <div class="max-w-6xl mx-auto px-6 pt-16 pb-12 grid md:grid-cols-3 gap-12 items-start">

    <!-- MARCA -->
    <div class="flex flex-col items-center md:items-start text-center md:text-left">
      <Image src={logo} alt="Lashes Esmera" width={80} height={80} class="opacity-90" />
      <p class="mt-5 text-gray-400 leading-relaxed text-sm max-w-xs">
        Especialistas en cejas y pestañas en Madrid. Formación, servicios y productos profesionales para lash artists.
      </p>
      <!-- Redes sociales -->
      <div class="flex items-center gap-3 mt-6">
        <!-- Instagram -->
        <a href="https://instagram.com/lashesesmera" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Lashes Esmera"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="background: rgba(241,205,240,0.1); border: 1px solid rgba(241,205,240,0.15);"
          onmouseover="this.style.background='rgba(241,205,240,0.2)'; this.style.borderColor='rgba(241,205,240,0.3)';"
          onmouseout="this.style.background='rgba(241,205,240,0.1)'; this.style.borderColor='rgba(241,205,240,0.15)';"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: #c9a0c7;">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
        <!-- TikTok -->
        <a href="https://tiktok.com/@lashesesmera" target="_blank" rel="noopener noreferrer" aria-label="TikTok de Lashes Esmera"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="background: rgba(241,205,240,0.1); border: 1px solid rgba(241,205,240,0.15);"
          onmouseover="this.style.background='rgba(241,205,240,0.2)'; this.style.borderColor='rgba(241,205,240,0.3)';"
          onmouseout="this.style.background='rgba(241,205,240,0.1)'; this.style.borderColor='rgba(241,205,240,0.15)';"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: #c9a0c7;">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.27 6.27 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.75a4.85 4.85 0 01-1.01-.06z"/>
          </svg>
        </a>
        <!-- Facebook -->
        <a href="https://facebook.com/lashesesmera" target="_blank" rel="noopener noreferrer" aria-label="Facebook de Lashes Esmera"
          class="w-9 h-9 rounded-full flex items-center justify-center transition-all duration-200 hover:scale-110"
          style="background: rgba(241,205,240,0.1); border: 1px solid rgba(241,205,240,0.15);"
          onmouseover="this.style.background='rgba(241,205,240,0.2)'; this.style.borderColor='rgba(241,205,240,0.3)';"
          onmouseout="this.style.background='rgba(241,205,240,0.1)'; this.style.borderColor='rgba(241,205,240,0.15)';"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="color: #c9a0c7;">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- NAVEGACIÓN -->
    <div class="flex flex-col items-center text-center">
      <h4 class="text-xs font-semibold tracking-widest mb-6 text-gray-500 uppercase">
        Navegación
      </h4>
      <ul class="space-y-3 text-sm">
        <li><a href="/" class="text-gray-400 hover:text-white transition">Inicio</a></li>
        <li><a href="/servicios" class="text-gray-400 hover:text-white transition">Servicios</a></li>
        <li><a href="/formacion" class="text-gray-400 hover:text-white transition">Formación</a></li>
        <li>
          <a href="/tienda" class="text-gray-400 hover:text-white transition">
            Tienda
          </a>
        </li>
        <li><a href="/sobre-nosotros" class="text-gray-400 hover:text-white transition">Nosotros</a></li>
        <li><a href="/contacto" class="text-gray-400 hover:text-white transition">Contacto</a></li>
      </ul>
    </div>

    <!-- CONTACTO -->
    <div class="flex flex-col items-center md:items-end text-center md:text-right">
      <h4 class="text-xs font-semibold tracking-widest mb-6 text-gray-500 uppercase">
        Contacto
      </h4>
      <p class="text-gray-400 text-sm">Madrid, España</p>
      <a href="tel:+34600000000" class="mt-3 text-gray-400 text-sm hover:text-white transition">
        +34 600 00 00 00
      </a>
      <a href="mailto:info@lashesesmera.com" class="text-gray-400 text-sm hover:text-white transition">
        info@lashesesmera.com
      </a>
      <a
        href="https://wa.me/34600000000"
        class="mt-6 inline-block px-6 py-2.5 rounded-full text-xs font-semibold tracking-wide transition hover:scale-105"
        style="background: #f1cdf0; color: #5c2d5a;"
      >
        RESERVAR POR WHATSAPP
      </a>
    </div>
  </div>

  <!-- DIVISOR -->
  <div class="max-w-6xl mx-auto px-6">
    <div class="border-t border-white/10"></div>
  </div>

  <!-- FOOTER BOTTOM -->
  <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-600">
    <p>© {currentYear} Lashes Esmera. Todos los derechos reservados.</p>
    <div class="flex gap-5">
      <a href="/politica-privacidad" class="hover:text-gray-300 transition">Privacidad</a>
      <a href="/terminos" class="hover:text-gray-300 transition">Términos</a>
      <a href="/aviso-legal" class="hover:text-gray-300 transition">Legal</a>
    </div>
  </div>

</footer>
