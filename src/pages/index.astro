---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Lashes Esmera | Formación, servicios y productos de cejas y pestañas en Madrid"
  description="Especialistas en cejas y pestañas en Madrid. Formación profesional, servicios de estudio y productos para lash artists."
  canonical="https://lashesesmera.com/"
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex items-center overflow-hidden">

    <img
      src="/nosotros/hero.png"
      alt="Lashes Esmera Madrid"
      class="absolute inset-0 w-full h-full object-cover object-center scale-[1.02]"
    />

    <!-- Overlay: oscuro a la izquierda para legibilidad, abierto a la derecha -->
    <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.65) 45%, rgba(0,0,0,0.25) 100%)"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 py-40">
      <div class="md:max-w-[55%]">

        <p class="text-[#f1cdf0] text-xs uppercase tracking-[0.45em] font-medium mb-8">
          Madrid · Especialistas en mirada
        </p>

        <h1 class="text-[clamp(2.8rem,7vw,5.5rem)] font-bold text-white leading-[1.0] tracking-tight mb-8">
          La mirada<br/>que te<br/>diferencia.
        </h1>

        <p class="text-white/65 text-base md:text-lg leading-relaxed mb-12 max-w-sm">
          Formación profesional, servicios especializados y productos para lash artists en Madrid.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/formacion"
            class="bg-white text-black px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:bg-gray-100 transition"
          >
            Ver formación
          </a>
          <a
            href="https://wa.me/34600000000"
            class="border border-white/50 text-white px-9 py-3.5 rounded-full text-sm font-medium tracking-wide hover:bg-white hover:text-black transition"
          >
            Reservar cita
          </a>
        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40 z-10">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <div class="w-px h-10 bg-white/20"></div>
    </div>
  </section>


  <!-- ─── STATS ─────────────────────────────────────────────────── -->
  <section class="bg-black">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
      {[
        { n: "+20", label: "Años de experiencia" },
        { n: "+500", label: "Alumnas formadas" },
        { n: "5",   label: "Técnicas especializadas" },
        { n: "1",   label: "Estudio en Madrid" },
      ].map((s) => (
        <div class="flex flex-col items-center justify-center text-center py-10 px-4">
          <span class="text-3xl md:text-4xl font-bold text-white tracking-tight">{s.n}</span>
          <span class="text-[10px] text-white/35 uppercase tracking-widest mt-2 leading-tight max-w-[90px]">{s.label}</span>
        </div>
      ))}
    </div>
  </section>


  <!-- ─── FORMACIÓN ─────────────────────────────────────────────── -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-[1fr_1.15fr] gap-16 items-center">

      <div>
        <p class="text-xs uppercase tracking-[0.38em] text-[#b89fb7] font-medium mb-7">Formación Profesional</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold leading-[1.05] tracking-tight mb-8">
          Aprende con<br/>las mejores<br/>del sector
        </h2>
        <p class="text-gray-500 leading-relaxed mb-8 max-w-sm">
          Más de 20 años formando lash artists en Madrid. Grupos de máximo 4 alumnas, práctica real desde el primer día y certificado profesional incluido.
        </p>

        <ul class="space-y-5 mb-10">
          {[
            "Certificado profesional incluido",
            "Modelos reales desde el primer día",
            "Modalidad presencial y online",
            "Grupos reducidos, máximo 4 alumnas",
          ].map((item) => (
            <li class="flex items-center gap-4 text-sm text-gray-700">
              <span class="w-6 h-px bg-black flex-shrink-0 block"></span>
              {item}
            </li>
          ))}
        </ul>

        <a
          href="/formacion"
          class="bg-black text-white px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:bg-gray-800 transition inline-block"
        >
          Ver cursos disponibles
        </a>
      </div>

      <div class="overflow-hidden rounded-2xl">
        <img
          src="/services/formacion.png"
          alt="Formación profesional de cejas y pestañas Madrid"
          class="w-full h-[540px] object-cover hover:scale-[1.03] transition duration-700"
        />
      </div>

    </div>
  </section>


  <!-- ─── SERVICIOS (sección oscura) ───────────────────────────── -->
  <section class="bg-[#0f0f0f] py-32 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

      <div class="overflow-hidden rounded-2xl order-2 md:order-1">
        <img
          src="/nosotros/centro.png"
          alt="Estudio Lashes Esmera Madrid"
          class="w-full h-[520px] object-cover hover:scale-[1.03] transition duration-700"
        />
      </div>

      <div class="order-1 md:order-2">
        <p class="text-xs uppercase tracking-[0.38em] text-[#f1cdf0] font-medium mb-7">Estudio en Madrid</p>
        <h2 class="text-[clamp(2rem,4.5vw,3.5rem)] font-bold text-white leading-[1.05] tracking-tight mb-8">
          Servicios<br/>profesionales
        </h2>
        <p class="text-white/45 text-sm leading-relaxed mb-10 max-w-sm">
          Extensiones de pestañas, lifting, laminado y diseño de cejas. Técnicas actualizadas, productos de alta gama y resultados que hablan por sí solos.
        </p>

        <div class="mb-10">
          {[
            { name: "Lifting de pestañas",        price: "desde 50€" },
            { name: "Extensiones volumen ruso",   price: "desde 95€" },
            { name: "Laminado de cejas",           price: "desde 45€" },
            { name: "Diseño de cejas",             price: "desde 20€" },
          ].map((s) => (
            <div class="flex justify-between items-center py-4 border-b border-white/8">
              <span class="text-white/75 text-sm font-medium">{s.name}</span>
              <span class="text-white/35 text-sm tabular-nums">{s.price}</span>
            </div>
          ))}
        </div>

        <a
          href="/servicios"
          class="border border-white/25 text-white px-9 py-3.5 rounded-full text-sm font-medium tracking-wide hover:bg-white hover:text-black transition inline-block"
        >
          Ver todos los precios
        </a>
      </div>

    </div>
  </section>


  <!-- ─── TIENDA ────────────────────────────────────────────────── -->
  <section class="py-32 px-6">
    <div class="max-w-5xl mx-auto text-center">

      <p class="text-xs uppercase tracking-[0.38em] text-gray-400 font-medium mb-6">Tienda Online</p>
      <h2 class="text-[clamp(2rem,4.5vw,3.2rem)] font-bold tracking-tight leading-tight mb-6">
        Material profesional<br/>para lash artists
      </h2>
      <p class="text-gray-500 max-w-md mx-auto leading-relaxed mb-16">
        Pinzas, adhesivos, kits y todo lo que necesitas. Testado y seleccionado por nuestras expertas.
      </p>

      <div class="grid md:grid-cols-3 gap-6 mb-16 pt-10 border-t border-gray-100">
        {[
          { title: "Calidad garantizada",  desc: "Testado por profesionales del sector" },
          { title: "Envíos en 24–48 h",    desc: "Entrega rápida en toda España" },
          { title: "Asesoramiento experto", desc: "Te ayudamos a elegir lo mejor" },
        ].map((f) => (
          <div class="text-center">
            <p class="font-semibold mb-1.5 text-sm">{f.title}</p>
            <p class="text-gray-400 text-sm">{f.desc}</p>
          </div>
        ))}
      </div>

      <a
        href="https://tienda.lashesesmera.com"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-black text-white px-12 py-4 rounded-full text-sm font-semibold tracking-wide hover:bg-gray-800 transition inline-block"
      >
        Visitar la tienda →
      </a>

    </div>
  </section>


  <!-- ─── CTA FINAL ─────────────────────────────────────────────── -->
  <section class="bg-[#f1cdf0] py-28 px-6">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.38em] text-black/40 font-medium mb-7">Tu nueva carrera te espera</p>
      <h2 class="text-[clamp(2.2rem,5vw,3.5rem)] font-bold mb-7 leading-[1.05] tracking-tight">
        Empieza hoy.
      </h2>
      <p class="text-gray-700 mb-10 leading-relaxed text-base">
        Formación, productos y servicios profesionales en un solo lugar.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="/formacion"
          class="bg-black text-white px-10 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:bg-gray-800 transition"
        >
          Quiero formarme
        </a>
        <a
          href="https://wa.me/34600000000"
          class="border border-black text-black px-10 py-3.5 rounded-full text-sm font-medium tracking-wide hover:bg-black hover:text-white transition"
        >
          Reservar cita
        </a>
      </div>
    </div>
  </section>

</Layout>
