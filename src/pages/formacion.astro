---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const cursos = await getCollection("cursos");
const cursosOrdenados = cursos.sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---

<Layout
  title="Cursos de cejas y pestañas en Madrid | Lashes Esmera"
  description="Fórmate en extensiones de pestañas, volumen ruso, lifting y cejas. Cursos profesionales en Madrid y online."
  canonical="https://lashesesmera.com/formacion"
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative h-[88vh] min-h-[580px] flex items-center overflow-hidden">

    <img
      src="/courses/hero-formacion.png"
      alt="Cursos de cejas y pestañas en Madrid"
      class="absolute inset-0 w-full h-full object-cover scale-[1.03]"
    />

    <div class="absolute inset-0" style="background: linear-gradient(110deg, rgba(45,18,41,0.90) 0%, rgba(45,18,41,0.60) 55%, rgba(74,30,70,0.30) 100%);"></div>

    <!-- Línea decorativa inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(241,205,240,0.35), transparent);"></div>

    <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-10">
      <div class="max-w-[580px]">

        <div class="hero-eyebrow flex items-center gap-3 mb-8">
          <span class="block w-7 h-px" style="background: #f1cdf0; opacity: 0.6;"></span>
          <p class="text-[10.5px] uppercase tracking-[0.45em] font-medium" style="color: #f1cdf0;">
            Formación Profesional · Madrid
          </p>
        </div>

        <h1 class="hero-h1 text-[clamp(2.8rem,6.5vw,5rem)] font-bold text-white leading-[1.0] tracking-tight mb-7">
          Domina el arte<br/>
          <em class="not-italic font-light" style="color: rgba(241,205,240,0.7);">de la mirada.</em>
        </h1>

        <p class="hero-p text-base md:text-lg leading-relaxed mb-10 max-w-[380px]" style="color: rgba(255,255,255,0.55);">
          Aprende lifting, laminado y extensiones de pestañas con más de 20 años de experiencia a tu lado.
        </p>

        <div class="hero-ctas flex flex-wrap gap-4">
          <a
            href="#cursos"
            class="inline-flex items-center gap-2 text-white px-9 py-3.5 rounded-full text-sm font-semibold tracking-wide hover:scale-105 transition-all duration-200"
            style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 22px rgba(156,90,150,0.4);"
          >
            Ver cursos disponibles
          </a>
          <a
            href="https://wa.me/34600000000"
            class="inline-flex items-center gap-2 px-9 py-3.5 rounded-full text-sm font-medium tracking-wide hover:scale-105 transition-all duration-200"
            style="border: 1.5px solid rgba(241,205,240,0.35); color: rgba(241,205,240,0.85);"
            onmouseover="this.style.background='rgba(241,205,240,0.1)'" onmouseout="this.style.background=''"
          >
            Consultar por WhatsApp
          </a>
        </div>

        <!-- Mini-stats -->
        <div class="hero-stats mt-12 pt-8 flex items-center gap-8" style="border-top: 1px solid rgba(241,205,240,0.12);">
          {[
            { n: "+20 años", label: "de experiencia" },
            { n: "+500",     label: "alumnas formadas" },
            { n: "100%",   label: "práctico" },
          ].map(s => (
            <div class="flex flex-col">
              <span class="text-lg font-bold text-white leading-none">{s.n}</span>
              <span class="text-[10px] uppercase tracking-widest mt-1.5" style="color: rgba(241,205,240,0.45);">{s.label}</span>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ─── BENEFICIOS ────────────────────────────────────────────── -->
  <section class="py-28 px-6" style="background: #fdf6fd;">
    <div class="max-w-5xl mx-auto">

      <div data-animate class="text-center mb-20">
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-4" style="color: #c9a0c7;">Por qué elegirnos</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #2d1229;">¿Por qué formarte con nosotros?</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-0 divide-y md:divide-y-0 md:divide-x" style="border-color: rgba(201,160,199,0.2);">

        <div data-animate data-delay="0" class="py-10 md:py-0 md:px-14 first:pl-0 last:pr-0">
          <span class="font-bold leading-none block mb-5 tracking-tight select-none" style="font-size: clamp(3.5rem,7vw,5rem); color: #f1cdf0;">01</span>
          <h3 class="font-bold text-lg mb-3" style="color: #2d1229;">100% práctico</h3>
          <p class="text-sm leading-relaxed" style="color: #9c7a9a;">
            Aprendes trabajando desde el primer día con modelos reales. Sin teoría vacía, solo técnica que funciona en el mercado.
          </p>
        </div>

        <div data-animate data-delay="150" class="py-10 md:py-0 md:px-14">
          <span class="font-bold leading-none block mb-5 tracking-tight select-none" style="font-size: clamp(3.5rem,7vw,5rem); color: #f1cdf0;">02</span>
          <h3 class="font-bold text-lg mb-3" style="color: #2d1229;">Más de 20 años</h3>
          <p class="text-sm leading-relaxed" style="color: #9c7a9a;">
            Experiencia real formando profesionales que hoy trabajan en los mejores centros de España.
          </p>
        </div>

        <div data-animate data-delay="300" class="py-10 md:py-0 md:px-14 last:pr-0">
          <span class="font-bold leading-none block mb-5 tracking-tight select-none" style="font-size: clamp(3.5rem,7vw,5rem); color: #f1cdf0;">03</span>
          <h3 class="font-bold text-lg mb-3" style="color: #2d1229;">Alta rentabilidad</h3>
          <p class="text-sm leading-relaxed" style="color: #9c7a9a;">
            Convierte tu formación en ingresos reales desde el primer mes de trabajo.
          </p>
        </div>

      </div>
    </div>
  </section>


  <!-- ─── CURSOS ────────────────────────────────────────────────── -->
  <section id="cursos" class="py-28 px-6 bg-white">
    <div class="max-w-6xl mx-auto">

      <div data-animate class="text-center mb-16">
        <p class="text-xs uppercase tracking-[0.38em] font-medium mb-4" style="color: #c9a0c7;">Programa formativo</p>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight" style="color: #2d1229;">Nuestros cursos</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-7">
        {cursosOrdenados.map((curso, i) => (
          <a
            href={`/formacion/${curso.id}`}
            data-animate
            data-delay={String(i * 120)}
            class="group overflow-hidden flex flex-col rounded-2xl bg-white transition-all duration-300 hover:-translate-y-1.5"
            style="border: 1px solid rgba(201,160,199,0.2); box-shadow: 0 2px 16px rgba(156,90,150,0.06);"
            onmouseover="this.style.boxShadow='0 12px 40px rgba(156,90,150,0.14)'; this.style.borderColor='rgba(201,160,199,0.4)';"
            onmouseout="this.style.boxShadow='0 2px 16px rgba(156,90,150,0.06)'; this.style.borderColor='rgba(201,160,199,0.2)';"
          >
            <!-- Imagen -->
            <div class="aspect-[4/3] overflow-hidden relative">
              <img
                src={curso.data.thumbnail}
                alt={curso.data.title}
                class="w-full h-full object-cover group-hover:scale-[1.07] transition-transform duration-700"
              />
              <!-- Badge de modalidad sobre imagen -->
              <span
                class="absolute top-3.5 left-3.5 text-[9.5px] px-3 py-1.5 rounded-full font-bold tracking-widest uppercase"
                style={curso.data.modality === "Online"
                  ? "background: #f1cdf0; color: #5c2d5a;"
                  : "background: #2d1229; color: #f1cdf0;"}
              >
                {curso.data.modality}
              </span>
            </div>

            <!-- Contenido -->
            <div class="p-6 flex flex-col flex-1">

              <h3 class="font-bold text-[17px] leading-snug mb-2.5" style="color: #2d1229;">
                {curso.data.title}
              </h3>

              <p class="text-sm leading-relaxed mb-5 flex-1" style="color: #9c7a9a;">
                {curso.data.short_description}
              </p>

              {curso.data.benefits && (
                <ul class="mb-5 space-y-2">
                  {curso.data.benefits.slice(0, 2).map((b) => (
                    <li class="flex items-center gap-2.5 text-xs" style="color: #7a4a78;">
                      <span class="w-3 h-px flex-shrink-0 block" style="background: #c9a0c7;"></span>
                      {b}
                    </li>
                  ))}
                </ul>
              )}

              <div class="flex items-center justify-between pt-4" style="border-top: 1px solid rgba(201,160,199,0.15);">
                <span class="text-sm font-semibold" style="color: #5c2d5a;">Ver curso</span>
                <span
                  class="w-7 h-7 rounded-full flex items-center justify-center text-xs transition-all duration-200 group-hover:translate-x-1"
                  style="background: #f1cdf0; color: #5c2d5a;"
                >→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── GARANTÍAS ────────────────────────────────────────────── -->
  <section class="py-20 px-6" style="background: #f4eef4;">
    <div class="max-w-5xl mx-auto grid md:grid-cols-4 gap-0 divide-y md:divide-y-0 md:divide-x" style="border-color: rgba(201,160,199,0.25);">
      {[
        { icon: "M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z", label: "Certificado profesional incluido" },
        { icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z", label: "Grupos reducidos y personalizados" },
        { icon: "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5", label: "Modelos reales desde día 1" },
        { icon: "M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5", label: "Presencial y online" },
      ].map((g, i) => (
        <div data-animate data-delay={String(i * 100)} class="flex flex-col items-center text-center py-10 md:py-6 md:px-8 gap-4 first:pl-0 last:pr-0">
          <div class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0" style="background: #f1cdf0;">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: #9c5a96;">
              <path stroke-linecap="round" stroke-linejoin="round" d={g.icon}/>
            </svg>
          </div>
          <p class="text-sm font-medium leading-snug" style="color: #5c2d5a;">{g.label}</p>
        </div>
      ))}
    </div>
  </section>


  <!-- ─── CTA ───────────────────────────────────────────────────── -->
  <section class="bg-[#f1cdf0] py-28 px-6 text-center relative overflow-hidden">
    <!-- Blob decorativo -->
    <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-full opacity-30" style="background: radial-gradient(ellipse 60% 80% at 50% 0%, #9c5a96 0%, transparent 70%);"></div>

    <div data-animate class="max-w-lg mx-auto relative z-10">
      <p class="text-xs uppercase tracking-[0.38em] font-medium mb-6" style="color: #9c5a96;">Empieza tu camino</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-5 tracking-tight leading-tight" style="color: #2d1229;">
        ¿Tienes dudas?<br/>Escríbenos.
      </h2>
      <p class="mb-10 leading-relaxed" style="color: #5c2d5a;">
        Cuéntanos tu situación y te recomendamos el curso que mejor se adapta a ti.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a
          href="https://wa.me/34600000000"
          class="inline-flex items-center justify-center gap-2 text-white px-10 py-3.5 rounded-full text-sm font-semibold hover:scale-105 transition-all duration-200"
          style="background: #5c2d5a; box-shadow: 0 4px 20px rgba(92,45,90,0.35);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultar por WhatsApp
        </a>
        <a
          href="#cursos"
          class="inline-flex items-center justify-center px-10 py-3.5 rounded-full text-sm font-medium hover:scale-105 transition-all duration-200"
          style="border: 1.5px solid #9c5a96; color: #5c2d5a;"
          onmouseover="this.style.background='rgba(92,45,90,0.08)';" onmouseout="this.style.background='';"
        >
          Ver todos los cursos
        </a>
      </div>
    </div>
  </section>

</Layout>
