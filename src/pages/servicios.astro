---
import Layout from "../layouts/Layout.astro";

const pestanas = [
  { name: "Lifting de pestañas con tinte",  desc: "Eleva y curva las pestañas desde la raíz.",   pro: "50€", student: "35€" },
  { name: "Lifting coreano",                desc: "Nutrición profunda y acabado natural.",         pro: "55€", student: "40€" },
  { name: "Pestañas pelo a pelo",           desc: "Resultado natural y elegante.",                pro: "70€", student: "50€" },
  { name: "Pestañas clásicas",              desc: "Longitud y definición sutil.",                 pro: "65€", student: "45€" },
  { name: "Volumen",                        desc: "Mayor densidad e intensidad.",                 pro: "80€", student: "55€" },
  { name: "Volumen ruso",                   desc: "Máxima densidad y glamour.",                   pro: "95€", student: "70€" },
];

const cejas = [
  { name: "Laminado de cejas con tinte", desc: "Cejas definidas, voluminosas y peinadas.", pro: "45€", student: "30€" },
  { name: "Tinte de cejas",              desc: "Intensifica el color y define.",           pro: "15€", student: "10€" },
  { name: "Epilación de cejas",          desc: "Hilo, cera o pinza.",                      pro: "12€", student: "8€"  },
  { name: "Diseño de cejas",             desc: "Visagismo personalizado.",                 pro: "20€", student: "15€" },
];
---

<Layout
  title="Precios de cejas y pestañas en Madrid | Lashes Esmera"
  description="Servicios profesionales de cejas y pestañas en Madrid. Consulta precios y reserva fácilmente."
  canonical="https://lashesesmera.com/servicios"
>

  <!-- HERO -->
  <section class="relative flex items-center justify-center text-center overflow-hidden" style="height: 62vh; min-height: 440px;">

    <img
      src="/services/hero-services.png"
      alt="Servicios de cejas y pestañas Lashes Esmera Madrid"
      class="absolute inset-0 w-full h-full object-cover object-center scale-[1.03]"
    />

    <!-- Overlay plum degradado -->
    <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(45,18,41,0.72) 0%, rgba(74,30,70,0.55) 50%, rgba(45,18,41,0.80) 100%);"></div>

    <!-- Línea decorativa inferior -->
    <div class="absolute bottom-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(241,205,240,0.4), transparent);"></div>

    <div class="relative z-10 px-6 max-w-2xl mx-auto">

      <p class="hero-eyebrow text-[10.5px] uppercase tracking-[0.45em] font-medium mb-6" style="color: #f1cdf0;">
        Estudio en Madrid
      </p>

      <h1 class="hero-h1 text-[clamp(2.6rem,6vw,4.5rem)] font-bold leading-[1.0] tracking-tight mb-6 text-white">
        Servicios<br/>
        <em class="not-italic font-light" style="color: rgba(241,205,240,0.75);">y precios</em>
      </h1>

      <p class="hero-p text-base md:text-lg leading-relaxed mb-10 max-w-sm mx-auto" style="color: rgba(241,205,240,0.65);">
        Resultados personalizados para realzar tu mirada. Reserva directamente por WhatsApp.
      </p>

      <div class="hero-ctas flex flex-wrap justify-center gap-4">
        <a
          href="https://wa.me/34600000000"
          class="inline-flex items-center gap-2 text-white px-8 py-3.5 rounded-full text-sm font-semibold hover:scale-105 transition-all duration-200"
          style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 22px rgba(156,90,150,0.4);"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
          </svg>
          Reservar por WhatsApp
        </a>
        <a
          href="#precios"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-medium hover:scale-105 transition-all duration-200"
          style="border: 1.5px solid rgba(241,205,240,0.4); color: rgba(241,205,240,0.85);"
          onmouseover="this.style.background='rgba(241,205,240,0.1)'" onmouseout="this.style.background=''"
        >
          Ver precios
        </a>
      </div>

    </div>
  </section>


  <!-- TABLAS DE PRECIOS -->
  <section id="precios" class="py-20 px-6 max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-10">

      <!-- PESTAÑAS -->
      <div data-animate data-delay="0" class="bg-white rounded-2xl p-8 hover:shadow-lg transition-shadow duration-300" style="border: 1px solid rgba(201,160,199,0.2); box-shadow: 0 2px 16px rgba(156,90,150,0.06);">
        <h2 class="text-xl font-semibold mb-8 pb-4" style="color: #2d1229; border-bottom: 1px solid rgba(201,160,199,0.2);">Pestañas</h2>

        <div class="grid grid-cols-[1fr_190px] text-xs uppercase tracking-wide pb-3 mb-2" style="color: #c9a0c7;">
          <span>Servicio</span>
          <div class="grid grid-cols-2 text-right gap-2">
            <span>Profesional</span>
            <span>Alumno</span>
          </div>
        </div>

        <div class="space-y-5">
          {pestanas.map((s, i) => (
            <div
              data-animate
              data-delay={String(i * 80)}
              class="grid grid-cols-[1fr_190px] gap-4 py-4 last:border-0"
              style="border-bottom: 1px dashed rgba(201,160,199,0.2);"
            >
              <div>
                <p class="font-medium text-sm" style="color: #2d1229;">{s.name}</p>
                <p class="text-xs mt-0.5" style="color: #b89fb7;">{s.desc}</p>
              </div>
              <div class="grid grid-cols-2 gap-2 text-right text-sm">
                <span class="font-medium" style="color: #5c2d5a;">{s.pro}</span>
                <span style="color: #c9a0c7;">{s.student}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CEJAS -->
      <div data-animate data-delay="100" class="bg-white rounded-2xl p-8 hover:shadow-lg transition-shadow duration-300" style="border: 1px solid rgba(201,160,199,0.2); box-shadow: 0 2px 16px rgba(156,90,150,0.06);">
        <h2 class="text-xl font-semibold mb-8 pb-4" style="color: #2d1229; border-bottom: 1px solid rgba(201,160,199,0.2);">Cejas</h2>

        <div class="grid grid-cols-[1fr_190px] text-xs uppercase tracking-wide pb-3 mb-2" style="color: #c9a0c7;">
          <span>Servicio</span>
          <div class="grid grid-cols-2 text-right gap-2">
            <span>Profesional</span>
            <span>Alumno</span>
          </div>
        </div>

        <div class="space-y-5">
          {cejas.map((s, i) => (
            <div
              data-animate
              data-delay={String(i * 80)}
              class="grid grid-cols-[1fr_190px] gap-4 py-4 last:border-0"
              style="border-bottom: 1px dashed rgba(201,160,199,0.2);"
            >
              <div>
                <p class="font-medium text-sm" style="color: #2d1229;">{s.name}</p>
                <p class="text-xs mt-0.5" style="color: #b89fb7;">{s.desc}</p>
              </div>
              <div class="grid grid-cols-2 gap-2 text-right text-sm">
                <span class="font-medium" style="color: #5c2d5a;">{s.pro}</span>
                <span style="color: #c9a0c7;">{s.student}</span>
              </div>
            </div>
          ))}
        </div>

        <p class="mt-8 text-xs leading-relaxed rounded-xl p-4" style="color: #b89fb7; background: #fdf6fd;">
          Los precios de alumno aplican durante las sesiones de práctica supervisada. Consulta disponibilidad.
        </p>
      </div>

    </div>
  </section>


  <!-- CTA RESERVA -->
  <section class="bg-[#f1cdf0] py-20 px-6 text-center">
    <div data-animate class="max-w-lg mx-auto">
      <p class="text-xs uppercase tracking-[0.3em] font-medium mb-5" style="color: #9c5a96;">¿Lista para reservar?</p>
      <h2 class="text-3xl md:text-4xl font-semibold mb-5 leading-tight tracking-tight" style="color: #2d1229;">
        Reserva tu cita en Madrid
      </h2>
      <p class="mb-10 leading-relaxed" style="color: #5c2d5a;">
        Atención personalizada · Resultados profesionales · Respuesta rápida
      </p>
      <a
        href="https://wa.me/34600000000"
        class="inline-flex items-center gap-2 text-white px-10 py-3.5 rounded-full text-sm font-medium hover:scale-105 transition-all duration-200"
        style="background: #5c2d5a; box-shadow: 0 4px 18px rgba(92,45,90,0.3);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
        </svg>
        Reservar por WhatsApp
      </a>
    </div>
  </section>


  <!-- FORMACIÓN -->
  <section class="py-24 px-6 overflow-hidden">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">

      <div data-animate="left" class="overflow-hidden rounded-2xl" style="box-shadow: 0 4px 24px rgba(156,90,150,0.1);">
        <img
          src="/services/formacion.png"
          alt="Curso de cejas y pestañas en Madrid"
          class="w-full h-[400px] object-cover hover:scale-[1.04] transition duration-700"
        />
      </div>

      <div data-animate="right">
        <p class="text-xs uppercase tracking-[0.3em] font-medium mb-5" style="color: #c9a0c7;">Formación Profesional</p>
        <h2 class="text-3xl md:text-4xl font-semibold mb-5 leading-tight tracking-tight" style="color: #2d1229;">
          ¿Quieres formarte con nosotros?
        </h2>
        <p class="mb-7 leading-relaxed" style="color: #9c7a9a;">
          Aprende técnicas profesionales de cejas y pestañas con formación práctica, seguimiento real y resultados desde el primer día.
        </p>
        <ul class="space-y-3 mb-10">
          {[
            "Formación presencial y online",
            "Técnicas actualizadas y reales",
            "Acompañamiento personalizado",
          ].map((item, i) => (
            <li data-animate data-delay={String(i * 100)} class="flex items-center gap-3 text-sm" style="color: #5c2d5a;">
              <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: #c9a0c7;"></span>
              {item}
            </li>
          ))}
        </ul>
        <a
          href="/formacion"
          class="text-white px-9 py-3.5 rounded-full text-sm font-medium tracking-wide hover:scale-105 transition-all duration-200 inline-block"
          style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 18px rgba(156,90,150,0.22);"
        >
          Ver formaciones
        </a>
        <p class="mt-4 text-xs" style="color: #c9a0c7;">Plazas limitadas · Grupos reducidos</p>
      </div>
    </div>
  </section>

</Layout>
