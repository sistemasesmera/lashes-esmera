---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Servicios de cejas y pestañas en Madrid | Lashes Esmera"
  description="Extensiones de pestañas, lifting y laminado de cejas en Madrid. Resultados profesionales adaptados a tu estilo."
  canonical="https://lashesesmera.com/servicios"
/>
  <!-- HERO -->
  <section class="bg-[#f1cdf0] pt-32 pb-20 px-6 text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-black mb-6">
      Servicios de cejas y pestañas
    </h1>

    <p class="text-lg text-gray-800 max-w-xl mx-auto mb-8">
      Realza tu mirada con técnicas profesionales y resultados personalizados.
    </p>

    <a 
      href="https://wa.me/34600000000"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Reservar cita
    </a>
  </section>

  <!-- SERVICIOS -->
  <section class="py-24 px-6 max-w-6xl mx-auto">
    
    <div class="grid md:grid-cols-3 gap-8">

      <!-- Extensiones -->
      <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="h-48 bg-gray-200 flex items-center justify-center">
          <span class="text-gray-500">Imagen</span>
        </div>
        <div class="p-6 text-center">
          <h3 class="font-semibold mb-2">Extensiones de pestañas</h3>
          <p class="text-gray-600 text-sm">
            Clásicas, volumen y mega volumen adaptadas a tu estilo.
          </p>
        </div>
      </div>

      <!-- Lifting -->
      <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="h-48 bg-gray-200 flex items-center justify-center">
          <span class="text-gray-500">Imagen</span>
        </div>
        <div class="p-6 text-center">
          <h3 class="font-semibold mb-2">Lifting de pestañas</h3>
          <p class="text-gray-600 text-sm">
            Eleva y curva tus pestañas naturales sin extensiones.
          </p>
        </div>
      </div>

      <!-- Cejas -->
      <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="h-48 bg-gray-200 flex items-center justify-center">
          <span class="text-gray-500">Imagen</span>
        </div>
        <div class="p-6 text-center">
          <h3 class="font-semibold mb-2">Laminado de cejas</h3>
          <p class="text-gray-600 text-sm">
            Diseño, fijación y definición profesional de cejas.
          </p>
        </div>
      </div>

    </div>

  </section>

  <!-- EXPERIENCIA -->
  <section class="bg-gray-50 py-24 px-6 text-center">
    
    <h2 class="text-3xl font-semibold mb-10">
      ¿Por qué elegirnos?
    </h2>

    <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">

      <div>
        <h3 class="font-semibold mb-2">Especialistas</h3>
        <p class="text-gray-600 text-sm">
          Más de 20 años de experiencia en estética profesional.
        </p>
      </div>

      <div>
        <h3 class="font-semibold mb-2">Resultados personalizados</h3>
        <p class="text-gray-600 text-sm">
          Adaptamos cada servicio a tu tipo de rostro.
        </p>
      </div>

      <div>
        <h3 class="font-semibold mb-2">Productos de calidad</h3>
        <p class="text-gray-600 text-sm">
          Trabajamos con materiales profesionales.
        </p>
      </div>

    </div>

  </section>

  <!-- TESTIMONIOS -->
  <section class="py-24 px-6 max-w-6xl mx-auto text-center">
    
    <h2 class="text-3xl font-semibold mb-10">
      Opiniones de nuestras clientas
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

      <div class="bg-white p-6 rounded-xl shadow-sm">
        <p class="text-gray-600 text-sm mb-4">
          “Me encantó el resultado, súper profesionales.”
        </p>
        <span class="text-sm font-semibold">— Cliente</span>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm">
        <p class="text-gray-600 text-sm mb-4">
          “Las mejores pestañas que me han hecho.”
        </p>
        <span class="text-sm font-semibold">— Cliente</span>
      </div>

      <div class="bg-white p-6 rounded-xl shadow-sm">
        <p class="text-gray-600 text-sm mb-4">
          “Muy buen trato y resultados increíbles.”
        </p>
        <span class="text-sm font-semibold">— Cliente</span>
      </div>

    </div>

  </section>

  <!-- CTA FINAL -->
  <section class="bg-[#f1cdf0] py-16 px-6 text-center">
    
    <h2 class="text-2xl font-semibold mb-4">
      Reserva tu cita ahora
    </h2>

    <p class="text-gray-800 mb-6">
      Mejora tu mirada con nuestros especialistas.
    </p>

    <a 
      href="https://wa.me/34600000000"
      class="bg-black text-white px-8 py-3 rounded-full text-sm hover:bg-gray-800 transition"
    >
      Reservar por WhatsApp
    </a>

  </section>

</Layout>