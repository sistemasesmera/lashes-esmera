---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tienda Lashes Esmera | Próximamente"
  description="Nuestra tienda online de productos profesionales para lash artists estará disponible muy pronto. Déjanos tu email y te avisamos."
  canonical="https://lashesesmera.com/tienda"
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden flex items-center justify-center text-center" style="min-height: calc(100vh - 116px); background: #fff;">

    <!-- Blobs decorativos -->
    <div class="pointer-events-none absolute top-0 right-0 w-[50%] h-full" style="background: radial-gradient(ellipse 80% 70% at 100% 20%, rgba(241,205,240,0.22) 0%, transparent 70%);"></div>
    <div class="pointer-events-none absolute bottom-0 left-0 w-[40%] h-[50%]" style="background: radial-gradient(ellipse 80% 80% at 0% 100%, rgba(201,160,199,0.12) 0%, transparent 70%);"></div>

    <div class="relative z-10 max-w-xl mx-auto px-6 py-20">

      <!-- Badge "Próximamente" -->
      <div class="hero-eyebrow inline-flex items-center gap-2 px-4 py-2 rounded-full mb-10" style="background: #f1cdf0;">
        <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: #9c5a96;"></span>
        <span class="text-[10.5px] uppercase tracking-[0.4em] font-semibold" style="color: #5c2d5a;">Próximamente</span>
      </div>

      <!-- Icono decorativo -->
      <div class="hero-h1 flex justify-center mb-8">
        <div class="w-20 h-20 rounded-3xl flex items-center justify-center" style="background: linear-gradient(135deg, #fdf6fd 0%, #f1cdf0 100%); box-shadow: 0 8px 32px rgba(156,90,150,0.18);">
          <svg class="w-9 h-9" fill="none" stroke="currentColor" stroke-width="1.4" viewBox="0 0 24 24" style="color: #9c5a96;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-7.5 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
          </svg>
        </div>
      </div>

      <h1 class="text-[clamp(2rem,5vw,3.2rem)] font-bold leading-[1.05] tracking-tight mb-5" style="color: #2d1229;">
        Nuestra tienda<br/>
        <em class="not-italic font-light" style="color: #c9a0c7;">está en camino.</em>
      </h1>

      <p class="hero-p text-base leading-relaxed mb-4 max-w-sm mx-auto" style="color: #9c7a9a;">
        Pinzas, adhesivos, kits y productos profesionales seleccionados por nuestras expertas. Muy pronto disponible.
      </p>
      <p class="text-sm mb-10" style="color: #c9a0c7;">Déjanos tu email y serás de las primeras en enterarte.</p>

      <!-- Formulario de aviso -->
      <form id="notify-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4">
        <input
          type="email"
          name="email"
          placeholder="tu@email.com"
          required
          class="flex-1 px-5 py-3.5 rounded-full text-sm outline-none transition-all duration-200"
          style="border: 1.5px solid rgba(201,160,199,0.35); color: #2d1229; background: #fff;"
          onfocus="this.style.borderColor='#c9a0c7'; this.style.boxShadow='0 0 0 3px rgba(201,160,199,0.15)';"
          onblur="this.style.borderColor='rgba(201,160,199,0.35)'; this.style.boxShadow='none';"
        />
        <button
          type="submit"
          class="px-7 py-3.5 rounded-full text-sm font-semibold text-white whitespace-nowrap transition-all duration-200 hover:scale-105"
          style="background: linear-gradient(135deg, #c9a0c7 0%, #9c5a96 100%); box-shadow: 0 4px 18px rgba(156,90,150,0.28);"
        >
          Avisarme
        </button>
      </form>

      <!-- Mensaje de estado -->
      <p id="notify-msg" class="text-sm min-h-[20px]" style="color: #9c5a96;"></p>

      <!-- Separador -->
      <div class="flex items-center gap-4 my-10 max-w-xs mx-auto">
        <div class="flex-1 h-px" style="background: rgba(201,160,199,0.2);"></div>
        <span class="text-[10px] uppercase tracking-widest" style="color: #c9a0c7;">Mientras tanto</span>
        <div class="flex-1 h-px" style="background: rgba(201,160,199,0.2);"></div>
      </div>

      <!-- Links alternativos -->
      <div class="grid sm:grid-cols-2 gap-4 max-w-sm mx-auto">
        <a
          href="/servicios"
          class="flex flex-col items-center gap-2 p-5 rounded-2xl transition-all duration-200 hover:-translate-y-0.5"
          style="border: 1px solid rgba(201,160,199,0.2); background: #fff; box-shadow: 0 2px 12px rgba(156,90,150,0.05);"
          onmouseover="this.style.borderColor='rgba(201,160,199,0.45)'; this.style.boxShadow='0 6px 24px rgba(156,90,150,0.1)';"
          onmouseout="this.style.borderColor='rgba(201,160,199,0.2)'; this.style.boxShadow='0 2px 12px rgba(156,90,150,0.05)';"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: #9c5a96;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </svg>
          <span class="text-sm font-semibold" style="color: #2d1229;">Ver servicios</span>
          <span class="text-xs" style="color: #b89fb7;">Cejas y pestañas</span>
        </a>
        <a
          href="/formacion"
          class="flex flex-col items-center gap-2 p-5 rounded-2xl transition-all duration-200 hover:-translate-y-0.5"
          style="border: 1px solid rgba(201,160,199,0.2); background: #fff; box-shadow: 0 2px 12px rgba(156,90,150,0.05);"
          onmouseover="this.style.borderColor='rgba(201,160,199,0.45)'; this.style.boxShadow='0 6px 24px rgba(156,90,150,0.1)';"
          onmouseout="this.style.borderColor='rgba(201,160,199,0.2)'; this.style.boxShadow='0 2px 12px rgba(156,90,150,0.05)';"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" style="color: #9c5a96;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
          </svg>
          <span class="text-sm font-semibold" style="color: #2d1229;">Ver formación</span>
          <span class="text-xs" style="color: #b89fb7;">Cursos profesionales</span>
        </a>
      </div>

    </div>
  </section>

</Layout>


<script is:inline>
  const form = document.getElementById('notify-form');
  const msg  = document.getElementById('notify-msg');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email');
    if (!email) return;

    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    msg.textContent = '';

    try {
      const res = await fetch('https://esmera-manager-backend.onrender.com/leads', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: 'Suscriptor tienda',
          email,
          phone: '',
          course: 'Aviso apertura tienda',
          publicidad: false,
        }),
      });

      if (!res.ok) throw new Error();
      msg.textContent = '¡Perfecto! Te avisamos en cuanto la tienda esté lista.';
      msg.style.color = '#9c5a96';
      form.reset();
    } catch {
      msg.textContent = 'Algo salió mal. Inténtalo de nuevo.';
      msg.style.color = '#c97a7a';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Avisarme';
    }
  });
</script>
