---
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import TopBar from "../components/TopBar.astro";
import "../styles/global.css";

const {
  title = "Lashes Esmera | Expertos en cejas y pestañas en Madrid",
  description = "Especialistas en cejas y pestañas en Madrid. Ofrecemos servicios profesionales, formación especializada y productos para lash artists.",
  canonical = "https://lashesesmera.com",
  showNavbar = true,
  miniHeader = false,
  showFooter = true,
} = Astro.props;

const hasHeader = showNavbar || miniHeader;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <!-- META RESPONSIVE (CLAVE) -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta charset="UTF-8">
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=2100550244114532&ev=PageView&noscript=1"
      />
    </noscript>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta charset="UTF-8" />
    <meta
      name="keywords"
      content="extensiones de pestañas Madrid, lifting de pestañas, laminado de cejas, cursos estética Madrid"
    />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Lashes Esmera" />
    <meta
      property="og:image"
      content="https://i.ibb.co/qLkp56BH/og-image.png"
    />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    <!-- JSON-LD -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BeautySalon",
        "name": "Lashes Esmera",
        "url": "https://lashesesmera.com"
      }
    </script>
  </head>

  <body class="flex flex-col min-h-screen bg-white text-gray-900">
    <!-- HEADER -->
    {
      showNavbar ? (
        <header class="w-full fixed top-0 left-0 z-50">
          <TopBar />
          <Navbar />
        </header>
      ) : (
        miniHeader && (
          <header class="w-full py-4 bg-white shadow-sm fixed top-0 left-0 z-50">
            <div class="max-w-6xl mx-auto px-4 flex items-center justify-center">
              <a href="/" aria-label="Inicio">
                <img
                  src="/favicon-esmera.svg"
                  alt="Lashes Esmera"
                  class="h-8 md:h-10"
                />
              </a>
            </div>
          </header>
        )
      )
    }

    <!-- MAIN -->
    <main class={`flex-1 w-full ${hasHeader ? "pt-20 md:pt-[116px]" : ""}`}>
      <div class="w-full mx-auto">
        <slot />
      </div>
    </main>

    <!-- FOOTER -->
    {
      showFooter && (
        <footer class="w-full mt-auto">
          <Footer />
        </footer>
      )
    }

    <!-- FLOATING WHATSAPP -->
    <a
      href="https://wa.me/34600000000"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] hover:bg-[#1ebe5c] rounded-full flex items-center justify-center shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-110"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
        <path d="M20.52 3.48A11.82 11.82 0 0012.01 0C5.38 0 .01 5.37.01 12c0 2.11.55 4.17 1.6 5.98L0 24l6.17-1.62A11.94 11.94 0 0012.01 24c6.63 0 12-5.37 12-12 0-3.2-1.25-6.21-3.49-8.52zM12 21.82c-1.8 0-3.56-.48-5.1-1.39l-.36-.21-3.66.96.98-3.56-.23-.37A9.79 9.79 0 012.2 12c0-5.41 4.39-9.8 9.8-9.8 2.62 0 5.08 1.02 6.93 2.87A9.77 9.77 0 0121.8 12c0 5.41-4.39 9.82-9.8 9.82zm5.41-7.37c-.3-.15-1.77-.87-2.05-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.28-.47-2.43-1.5-.9-.8-1.5-1.78-1.67-2.08-.17-.3-.02-.46.13-.61.14-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.62-.92-2.22-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.8.37-.27.3-1.05 1.03-1.05 2.52s1.08 2.93 1.23 3.13c.15.2 2.13 3.26 5.17 4.57.72.31 1.28.5 1.72.64.72.23 1.38.2 1.9.12.58-.09 1.77-.72 2.02-1.42.25-.7.25-1.3.17-1.42-.07-.12-.27-.2-.57-.35z"/>
      </svg>
    </a>
  </body>
</html>

<!-- SCRIPT -->
<script src="/modal.js" type="module"></script>
